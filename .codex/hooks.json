{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/usr/bin/env python3 \"$(git rev-parse --show-toplevel)/scripts/agent-hooks/cargo-cache-pretool.py\"",
            "statusMessage": "Applying Terrane Cargo cache env",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
