{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/app-signature.schema.json",
  "title": "Installed App Signature",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "appId",
    "appVersion",
    "dataVersion",
    "runtimeVersion",
    "trustLevel",
    "algorithm",
    "manifestHash",
    "contentHash",
    "permissionsHash",
    "policyHash",
    "signedAt",
    "signedBy",
    "signature"
  ],
  "properties": {
    "appId": {
      "type": "string"
    },
    "appVersion": {
      "type": "string"
    },
    "dataVersion": {
      "type": "integer",
      "minimum": 1
    },
    "runtimeVersion": {
      "type": "string"
    },
    "trustLevel": {
      "type": "string",
      "enum": [
        "bundled",
        "user-generated",
        "developer",
        "remote",
        "quarantined"
      ]
    },
    "algorithm": {
      "type": "string",
      "enum": [
        "ed25519",
        "ed25519-dev",
        "none-dev"
      ]
    },
    "manifestHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "contentHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "permissionsHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "policyHash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "signedAt": {
      "type": "string",
      "format": "date-time"
    },
    "signedBy": {
      "type": "string",
      "minLength": 1
    },
    "signature": {
      "type": "string",
      "minLength": 1
    }
  }
}