{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/db-test-records.schema.json",
  "title": "Database Test and Control Records",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "microTests",
    "testRuns",
    "controlSessions",
    "controlCommands"
  ],
  "properties": {
    "microTests": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/microTestRecord"
      }
    },
    "testRuns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/testRun"
      }
    },
    "controlSessions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/controlSession"
      }
    },
    "controlCommands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/controlCommand"
      }
    },
    "networkMocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/networkMock"
      }
    },
    "dialogMocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/dialogMock"
      }
    },
    "faultInjections": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/faultInjection"
      }
    }
  },
  "$defs": {
    "microTestRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "microTestId",
        "name",
        "spec",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "microTestId": {
          "type": "string"
        },
        "appId": {
          "type": [
            "string",
            "null"
          ]
        },
        "name": {
          "type": "string"
        },
        "spec": {
          "type": "object"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "testRun": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "testRunId",
        "status",
        "startedAt"
      ],
      "properties": {
        "testRunId": {
          "type": "string"
        },
        "microTestId": {
          "type": [
            "string",
            "null"
          ]
        },
        "sessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "controlSessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "appId": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "enum": [
            "passed",
            "failed",
            "skipped",
            "running",
            "error"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "finishedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "result": {},
        "diagnostics": {}
      }
    },
    "controlSession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "controlSessionId",
        "target",
        "actor",
        "startedAt",
        "status"
      ],
      "properties": {
        "controlSessionId": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "runtimeSessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor": {
          "type": "string"
        },
        "tokenHash": {
          "type": [
            "string",
            "null"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "status": {
          "type": "string"
        },
        "metadata": {}
      }
    },
    "controlCommand": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "commandId",
        "controlSessionId",
        "tool",
        "createdAt"
      ],
      "properties": {
        "commandId": {
          "type": "string"
        },
        "controlSessionId": {
          "type": "string"
        },
        "runtimeSessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "tool": {
          "type": "string"
        },
        "httpMethod": {
          "type": [
            "string",
            "null"
          ]
        },
        "path": {
          "type": [
            "string",
            "null"
          ]
        },
        "decision": {
          "enum": [
            "accepted",
            "rejected",
            null
          ]
        },
        "errorCode": {
          "type": [
            "string",
            "null"
          ]
        },
        "args": {},
        "result": {},
        "error": {},
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "durationMs": {
          "type": [
            "integer",
            "null"
          ]
        }
      }
    },
    "networkMock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mockId",
        "urlPattern",
        "response",
        "createdAt"
      ],
      "properties": {
        "mockId": {
          "type": "string"
        },
        "sessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "appId": {
          "type": [
            "string",
            "null"
          ]
        },
        "method": {
          "type": "string"
        },
        "urlPattern": {
          "type": "string"
        },
        "response": {},
        "enabled": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "dialogMock": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mockId",
        "dialogType",
        "response",
        "createdAt"
      ],
      "properties": {
        "mockId": {
          "type": "string"
        },
        "sessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "appId": {
          "type": [
            "string",
            "null"
          ]
        },
        "dialogType": {
          "enum": [
            "openFile",
            "saveFile"
          ]
        },
        "response": {},
        "enabled": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "faultInjection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "faultId",
        "method",
        "code",
        "message",
        "createdAt"
      ],
      "properties": {
        "faultId": {
          "type": "string"
        },
        "sessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "appId": {
          "type": [
            "string",
            "null"
          ]
        },
        "method": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "details": {},
        "once": {
          "type": "boolean"
        },
        "enabled": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
