{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/network-policy.schema.json",
  "title": "NetworkPolicy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "allow"
  ],
  "properties": {
    "allow": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "origin",
          "methods"
        ],
        "properties": {
          "origin": {
            "type": "string",
            "pattern": "^https://[^/\\s]+(?::\\d+)?$"
          },
          "methods": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "enum": [
                "GET",
                "POST",
                "PUT",
                "PATCH",
                "DELETE"
              ]
            }
          },
          "pathPrefix": {
            "type": "string"
          },
          "allowedHeaders": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string"
            }
          },
          "maxRequestBytes": {
            "type": "integer",
            "minimum": 0
          },
          "maxResponseBytes": {
            "type": "integer",
            "minimum": 0
          },
          "timeoutMs": {
            "type": "integer",
            "minimum": 1,
            "maximum": 120000
          }
        }
      }
    },
    "denyPrivateNetwork": {
      "type": "boolean",
      "default": true,
      "description": "When omitted or true, bridge hosts reject loopback, private, and link-local literal targets before allow-rule matching."
    },
    "allowCredentials": {
      "const": false,
      "default": false,
      "description": "Reserved for a future credential design; v0.4 hosts reject credentialed requests."
    }
  }
}
