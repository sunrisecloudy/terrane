{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/micro-test.schema.json",
  "title": "PlatformMicroTest",
  "type": "object",
  "required": ["id", "targetApps", "steps"],
  "properties": {
    "id": { "type": "string" },
    "description": { "type": "string" },
    "targetApps": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "platforms": {
      "type": "array",
      "items": {
        "enum": ["fake-host", "macos", "ios-simulator", "android-emulator", "windows", "linux", "server"]
      }
    },
    "setup": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    },
    "steps": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" },
      "minItems": 1
    },
    "teardown": {
      "type": "array",
      "items": { "$ref": "#/$defs/step" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "step": {
      "type": "object",
      "required": ["tool", "args"],
      "properties": {
        "tool": { "type": "string" },
        "args": { "type": "object" },
        "expect": { "type": "object" }
      },
      "additionalProperties": false
    }
  }
}
