{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/app-version-record.schema.json",
  "title": "Installed App Version Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "appId",
    "appVersion",
    "installId",
    "status",
    "installedAt",
    "manifestHash",
    "contentHash",
    "dataVersion"
  ],
  "properties": {
    "appId": {
      "type": "string"
    },
    "appVersion": {
      "type": "string"
    },
    "installId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "installed",
        "enabled",
        "disabled",
        "quarantined",
        "rolled-back",
        "uninstalled"
      ]
    },
    "installedAt": {
      "type": "string",
      "format": "date-time"
    },
    "manifestHash": {
      "type": "string"
    },
    "contentHash": {
      "type": "string"
    },
    "dataVersion": {
      "type": "integer",
      "minimum": 1
    },
    "previousInstallId": {
      "type": "string"
    },
    "signature": {
      "$ref": "app-signature.schema.json"
    }
  }
}