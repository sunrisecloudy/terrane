{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/db-runtime-records.schema.json",
  "title": "Database Runtime Records",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "runtimeSessions",
    "bridgeCalls",
    "coreEvents",
    "coreActions",
    "runtimeSnapshots"
  ],
  "properties": {
    "runtimeSessions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/runtimeSession"
      }
    },
    "bridgeCalls": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/bridgeCall"
      }
    },
    "coreEvents": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coreEvent"
      }
    },
    "coreActions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/coreAction"
      }
    },
    "runtimeSnapshots": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/runtimeSnapshotRecord"
      }
    }
  },
  "$defs": {
    "runtimeSession": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sessionId",
        "target",
        "platform",
        "runtimeVersion",
        "startedAt",
        "status"
      ],
      "properties": {
        "sessionId": {
          "type": "string"
        },
        "target": {
          "type": "string"
        },
        "platform": {
          "type": "string"
        },
        "runtimeVersion": {
          "type": "string"
        },
        "activeAppId": {
          "type": [
            "string",
            "null"
          ]
        },
        "activeInstallId": {
          "type": [
            "string",
            "null"
          ]
        },
        "startedAt": {
          "type": "string",
          "format": "date-time"
        },
        "endedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "status": {
          "type": "string"
        },
        "capabilities": {
          "type": [
            "object",
            "null"
          ]
        },
        "metadata": {
          "type": [
            "object",
            "null"
          ]
        }
      }
    },
    "bridgeCall": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "bridgeCallId",
        "sessionId",
        "method",
        "createdAt"
      ],
      "properties": {
        "bridgeCallId": {
          "type": "string"
        },
        "sessionId": {
          "type": "string"
        },
        "appId": {
          "type": [
            "string",
            "null"
          ]
        },
        "installId": {
          "type": [
            "string",
            "null"
          ]
        },
        "method": {
          "type": "string"
        },
        "params": {},
        "result": {},
        "error": {},
        "durationMs": {
          "type": [
            "integer",
            "null"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "coreEvent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eventId",
        "event",
        "createdAt"
      ],
      "properties": {
        "eventId": {
          "type": "string"
        },
        "sessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "appId": {
          "type": [
            "string",
            "null"
          ]
        },
        "installId": {
          "type": [
            "string",
            "null"
          ]
        },
        "stateVersionBefore": {
          "type": [
            "integer",
            "null"
          ]
        },
        "event": {},
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "coreAction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "actionId",
        "eventId",
        "action",
        "createdAt"
      ],
      "properties": {
        "actionId": {
          "type": "string"
        },
        "eventId": {
          "type": "string"
        },
        "sessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "appId": {
          "type": [
            "string",
            "null"
          ]
        },
        "action": {},
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "runtimeSnapshotRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "snapshotId",
        "type",
        "snapshot",
        "contentHash",
        "createdAt"
      ],
      "properties": {
        "snapshotId": {
          "type": "string"
        },
        "sessionId": {
          "type": [
            "string",
            "null"
          ]
        },
        "appId": {
          "type": [
            "string",
            "null"
          ]
        },
        "installId": {
          "type": [
            "string",
            "null"
          ]
        },
        "type": {
          "type": "string"
        },
        "snapshot": {
          "type": "object"
        },
        "contentHash": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
