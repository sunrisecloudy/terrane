{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/bridge-contract-fixture.schema.json",
  "title": "BridgeContractFixture",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "context",
    "method",
    "params"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "context": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appId"
      ],
      "properties": {
        "appId": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9-]{2,63}$"
        }
      }
    },
    "method": {
      "type": "string",
      "minLength": 1
    },
    "params": {
      "type": "object"
    },
    "preconditions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "resourceBudget": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        },
        "manifestPatch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "runtimeVersion": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "networkMocks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "urlPattern",
              "response"
            ],
            "properties": {
              "method": {
                "type": "string"
              },
              "urlPattern": {
                "type": "string",
                "minLength": 1
              },
              "response": {
                "type": "object"
              }
            }
          }
        },
        "dialogMocks": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "dialogType",
              "response"
            ],
            "properties": {
              "dialogType": {
                "type": "string"
              },
              "response": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "timestamp": {
      "type": "integer"
    },
    "expected": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "errorCode": {
          "type": "string"
        },
        "resultOk": {
          "type": "boolean"
        },
        "resultErrorCode": {
          "type": "string"
        },
        "resultSubset": {
          "type": "object"
        },
        "errorDetailsSubset": {
          "type": "object"
        }
      }
    }
  }
}
