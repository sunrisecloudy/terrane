{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/bridge-request.schema.json",
  "title": "Runtime Bridge Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "method",
    "params",
    "timestamp"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "method": {
      "type": "string"
    },
    "params": {
      "type": "object"
    },
    "timestamp": {
      "type": "number"
    }
  }
}
