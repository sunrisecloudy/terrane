{
  "id": "form-storage",
  "description": "Form labels, validation, storage prefix, toast, and keyboard flow.",
  "targetApps": [
    "notes-lite"
  ],
  "platforms": [
    "fake-host"
  ],
  "setup": [
    {
      "tool": "platform.validate_package",
      "args": {
        "path": "webapps/examples/notes-lite"
      }
    },
    {
      "tool": "platform.sign_webapp_package",
      "args": {
        "path": "webapps/examples/notes-lite"
      }
    },
    {
      "tool": "platform.install_webapp_package",
      "args": {
        "path": "webapps/examples/notes-lite"
      }
    },
    {
      "tool": "platform.open_webapp",
      "args": {
        "appId": "notes-lite"
      }
    }
  ],
  "steps": [
    {
      "tool": "runtime.assert_visible",
      "args": {
        "selector": "[data-testid='note-title-input']"
      }
    },
    {
      "tool": "runtime.assert_accessibility",
      "args": {
        "rule": "labels"
      }
    },
    {
      "tool": "runtime.assert_accessibility",
      "args": {
        "rule": "focus-visible"
      }
    },
    {
      "tool": "runtime.assert_no_console_errors",
      "args": {}
    }
  ]
}
