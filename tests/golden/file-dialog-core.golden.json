{
  "id": "file-dialog-core",
  "description": "Open file dialog mock, send transformed data through core.step, save file mock.",
  "targetApps": [
    "file-transformer"
  ],
  "platforms": [
    "fake-host"
  ],
  "setup": [
    {
      "tool": "platform.validate_package",
      "args": {
        "path": "webapps/examples/file-transformer"
      }
    },
    {
      "tool": "platform.sign_webapp_package",
      "args": {
        "path": "webapps/examples/file-transformer"
      }
    },
    {
      "tool": "platform.install_webapp_package",
      "args": {
        "path": "webapps/examples/file-transformer"
      }
    },
    {
      "tool": "platform.open_webapp",
      "args": {
        "appId": "file-transformer"
      }
    },
    {
      "tool": "runtime.dialog_mock_set",
      "args": {
        "appId": "file-transformer",
        "dialogType": "openFile",
        "response": {
          "files": [
            {
              "name": "sample.txt",
              "mime": "text/plain",
              "text": "hello"
            }
          ]
        }
      }
    }
  ],
  "steps": [
    {
      "tool": "runtime.click",
      "args": {
        "selector": "[data-testid='open-file-button']"
      }
    },
    {
      "tool": "runtime.assert_bridge_call",
      "args": {
        "method": "dialog.openFile"
      }
    },
    {
      "tool": "runtime.click",
      "args": {
        "selector": "[data-testid='transform-button']"
      }
    },
    {
      "tool": "runtime.assert_bridge_call",
      "args": {
        "method": "core.step"
      }
    },
    {
      "tool": "runtime.click",
      "args": {
        "selector": "[data-testid='save-file-button']"
      }
    },
    {
      "tool": "runtime.assert_bridge_call",
      "args": {
        "method": "dialog.saveFile"
      }
    },
    {
      "tool": "runtime.assert_no_console_errors",
      "args": {}
    }
  ]
}
