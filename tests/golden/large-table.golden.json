{
  "id": "large-table",
  "description": "Virtual-list/table behavior and DOM-node budget enforcement.",
  "targetApps": [
    "task-workbench"
  ],
  "platforms": [
    "fake-host"
  ],
  "setup": [
    {
      "tool": "platform.validate_package",
      "args": {
        "path": "webapps/examples/task-workbench"
      }
    },
    {
      "tool": "platform.sign_webapp_package",
      "args": {
        "path": "webapps/examples/task-workbench"
      }
    },
    {
      "tool": "platform.install_webapp_package",
      "args": {
        "path": "webapps/examples/task-workbench"
      }
    },
    {
      "tool": "platform.open_webapp",
      "args": {
        "appId": "task-workbench"
      }
    }
  ],
  "steps": [
    {
      "tool": "runtime.snapshot",
      "args": {
        "includeResourceUsage": true
      },
      "expect": {
        "resourceUsage": {
          "maxDomNodesBelow": 5000
        }
      }
    },
    {
      "tool": "runtime.assert_no_console_errors",
      "args": {}
    }
  ]
}
