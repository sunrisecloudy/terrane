{
  "id": "all-example-apps-cross-platform-smoke",
  "platforms": ["reference-host", "macos", "linux", "windows", "android-emulator", "ios-simulator"],
  "apps": ["notes-lite", "task-workbench", "file-transformer", "api-dashboard", "core-replay-lab"],
  "stepsPerApp": [
    { "tool": "platform.open_webapp", "args": { "appId": "${appId}" } },
    { "tool": "runtime.wait_for", "args": { "kind": "idle" } },
    { "tool": "runtime.screenshot", "args": { "label": "${platform}-${appId}-initial" } },
    { "tool": "runtime.assert_no_console_errors", "args": {} },
    { "tool": "runtime.run_smoke_tests", "args": { "appId": "${appId}" } }
  ]
}
