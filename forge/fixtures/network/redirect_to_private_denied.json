{
  "case": "redirect_to_private_denied",
  "allowlist": [
    {
      "method": "GET",
      "url": "https://api.example.com/public/*",
      "max_response_bytes": 1048576,
      "timeout_ms": 2000,
      "response_content_types": [
        "application/json"
      ]
    }
  ],
  "request": {
    "method": "GET",
    "url": "https://api.example.com/public/redirect",
    "redirect_chain": [
      "https://api.example.com/public/redirect",
      "http://127.0.0.1/admin"
    ]
  },
  "expect": "deny",
  "reason": "redirect target must be rechecked and private target denied",
  "requires_runtime_dns": true
}
