{
  "case": "body_too_large_denied",
  "allowlist": [
    {
      "method": "POST",
      "url": "https://api.example.com/forms/*",
      "max_body_bytes": 1024
    }
  ],
  "request": {
    "method": "POST",
    "url": "https://api.example.com/forms/submit",
    "body_bytes": 2048
  },
  "expect": "deny",
  "reason": "request body exceeds max_body_bytes",
