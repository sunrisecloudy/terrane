{
  "case": "post_json_allowed",
  "allowlist": [
    {
      "method": "POST",
      "url": "https://api.example.com/forms/*",
      "max_body_bytes": 4096,
      "request_content_types": [
        "application/json"
      ]
    }
  ],
  "request": {
    "method": "POST",
    "url": "https://api.example.com/forms/submit",
    "body_bytes": 512,
    "request_content_type": "application/json"
  },
  "expect": "allow",
  "reason": "POST with bounded JSON body",
  "requires_runtime_dns": false
}
