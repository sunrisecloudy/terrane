{
  "case": "db_write_then_render",
  "kind": "dispatch",
  "applet": {
    "id": "example.tasks",
    "entrypoint": "render",
    "capabilities": {
      "db": [
        "tasks:write"
      ]
    }
  },
  "initial_state": {
    "tasks": []
  },
  "initial_tree": {
    "type": "Stack",
    "direction": "v",
    "children": [
      {
        "type": "Text",
        "testId": "empty-state",
        "text": "No tasks"
      },
      {
        "type": "Button",
        "testId": "add-task",
        "label": "Add task",
        "onTap": "tasks.add"
      }
    ]
  },
  "events": [
    {
      "action": "tasks.add",
      "event_type": "tap",
      "payload": {
        "title": "Draft spec"
      }
    }
  ],
  "expect": {
    "results": [
      {
        "db_writes": [
          {
            "op": "record.insert",
            "collection": "tasks",
            "id": "task-1",
            "fields": {
              "title": "Draft spec",
              "done": false
            }
          }
        ],
        "patches": [
          {
            "op": "replace",
            "path": [
              0
            ],
            "node": {
              "type": "List",
              "testId": "task-list",
              "items": [
                {
                  "type": "Text",
                  "id": "task-1",
                  "testId": "task-row-task-1",
                  "text": "Draft spec"
                }
              ]
            }
          }
        ]
      }
    ],
    "record_event_in_run": true,
    "deterministic": true
  }
}
