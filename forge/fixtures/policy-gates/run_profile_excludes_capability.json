{
  "version": 1,
  "case": "run_profile_excludes_capability",
  "coverage": ["SC-10", "SC-21"],
  "summary": "The run executes under a review-safety profile whose bounds exclude db, so gate 4 (run-profile) denies a granted db write.",
  "actor": { "role": "owner" },
  "manifest": {
    "capabilities": { "db": { "read": ["tasks"], "write": ["tasks"] } },
    "limits": { "max_host_calls": 100 }
  },
  "workspace_policy": { "allowed": ["db"], "denied": [] },
  "run_profile": { "name": "review-safety", "permitted": ["ui"] },
  "platform": { "granted": ["db"] },
  "request": { "call": "db", "op": "write", "collection": "tasks" },
  "expect": {
    "decision": "deny",
    "gate": "run-profile",
    "code": "PermissionDenied",
    "reason_contains": "run profile"
  }
}
