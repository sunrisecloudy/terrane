{
  "version": 1,
  "case": "resource_limit_exceeded_denied",
  "coverage": ["SC-10", "SC-2"],
  "summary": "The host-call budget (max_host_calls) is exhausted, so gate 7 (rate/resource-limit) denies with ResourceLimitExceeded. The case pre-spends the budget with `prefill_calls` allowed calls, then the asserted request is the one over the cap.",
  "actor": { "role": "owner" },
  "manifest": {
    "capabilities": { "storage": { "read": ["app/*"], "write": [] } },
    "limits": { "max_host_calls": 1 }
  },
  "workspace_policy": { "allowed": ["storage"], "denied": [] },
  "run_profile": { "name": "default", "permitted": ["storage"] },
  "platform": { "granted": ["storage"] },
  "prefill_calls": 1,
  "request": { "call": "storage", "op": "read", "key": "app/notes/1" },
  "expect": {
    "decision": "deny",
    "gate": "rate-resource-limit",
    "code": "ResourceLimitExceeded",
    "reason_contains": "host-call limit exceeded"
  }
}
