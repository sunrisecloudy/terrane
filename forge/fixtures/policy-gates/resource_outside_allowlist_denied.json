{
  "version": 1,
  "case": "resource_outside_allowlist_denied",
  "coverage": ["SC-10", "SC-8"],
  "summary": "The storage category IS declared, but the requested key is outside every granted scope, so gate 6 (resource-allowlist) denies with PermissionDenied.",
  "actor": { "role": "owner" },
  "manifest": {
    "capabilities": { "storage": { "read": ["app/*"], "write": [] } },
    "limits": { "max_host_calls": 100 }
  },
  "workspace_policy": { "allowed": ["storage"], "denied": [] },
  "run_profile": { "name": "default", "permitted": ["storage"] },
  "platform": { "granted": ["storage"] },
  "request": { "call": "storage", "op": "read", "key": "secret/keys" },
  "expect": {
    "decision": "deny",
    "gate": "resource-allowlist",
    "code": "PermissionDenied",
    "reason_contains": "secret/keys"
  }
}
