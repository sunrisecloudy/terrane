{
  "case": "retention_keeps_within_window_prunes_beyond",
  "prd": "DL-20",
  "describe": "compaction keeps change-feed entries within the retention window and may prune beyond it",
  "collection": "tasks",
  "record": "t1",
  "seed": [
    { "op": "insert", "id": "t1", "fields": { "title": "A" }, "logical_at": 1 },
    { "op": "patch",  "id": "t1", "fields": { "title": "B" }, "logical_at": 2 },
    { "op": "patch",  "id": "t1", "fields": { "title": "C" }, "logical_at": 3 },
    { "op": "patch",  "id": "t1", "fields": { "title": "D" }, "logical_at": 4 },
    { "op": "patch",  "id": "t1", "fields": { "title": "E" }, "logical_at": 5 }
  ],
  "assert": {
    "kind": "retention",
    "window": 2,
    "all_peers_acked": true,
    "expect_retained_versions": [4, 5],
    "expect_pruned_versions": [1, 2],
    "expect_current_fields": { "title": "E" },
    "expect_retained_state": [
      { "version": 4, "logical_at": 4, "state_fields": { "title": "D" } },
      { "version": 5, "logical_at": 5, "state_fields": { "title": "E" } }
    ]
  }
}
