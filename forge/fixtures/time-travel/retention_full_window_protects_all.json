{
  "case": "retention_full_window_protects_all",
  "prd": "DL-20",
  "describe": "a window wider than all history protects every change-feed entry from pruning",
  "collection": "tasks",
  "record": "t1",
  "seed": [
    { "op": "insert", "id": "t1", "fields": { "title": "A" }, "logical_at": 1 },
    { "op": "patch",  "id": "t1", "fields": { "title": "B" }, "logical_at": 2 },
    { "op": "patch",  "id": "t1", "fields": { "title": "C" }, "logical_at": 3 }
  ],
  "assert": {
    "kind": "retention",
    "window": 90,
    "all_peers_acked": true,
    "expect_retained_versions": [1, 2, 3],
    "expect_pruned_versions": [],
    "expect_current_fields": { "title": "C" }
  }
}
