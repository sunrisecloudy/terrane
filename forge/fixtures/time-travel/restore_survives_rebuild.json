{
  "case": "restore_survives_rebuild",
  "prd": "DL-20",
  "describe": "the restore op is in the CRDT source of truth, so a DL-6 rebuild reproduces the restored state",
  "collection": "tasks",
  "record": "t1",
  "seed": [
    { "op": "insert", "id": "t1", "fields": { "title": "A" }, "logical_at": 1 },
    { "op": "patch",  "id": "t1", "fields": { "title": "B" }, "logical_at": 2 }
  ],
  "assert": {
    "kind": "restore",
    "to_version": 1,
    "restored_logical_at": 3,
    "expect_new_version": 3,
    "expect_current_fields": { "title": "A" },
    "rebuild_then_expect_fields": { "title": "A" }
  }
}
