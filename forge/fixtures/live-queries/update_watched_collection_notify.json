{
  "case": "update_watched_collection_notify",
  "description": "Patching a record already in the watched result delivers one notification.",
  "given": {
    "records": [
      {"collection": "tasks", "id": "tasks/1", "fields": {"title": "Ship", "done": false}, "deleted": false}
    ],
    "watches": [
      {"watch_id": "watch:tasks-open", "query": {"from": "tasks", "where": ["done", "=", false], "orderBy": ["id", "asc"]}}
    ],
    "next_version": 7
  },
  "when": {
    "mutation": {"op": "patch", "collection": "tasks", "id": "tasks/1", "fields": {"title": "Ship v2"}}
  },
  "expect": {
    "dirty_set": {"version": 7, "collections": {"tasks": ["tasks/1"]}},
    "notifications": [
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-open",
        "version": 7,
        "collection": "tasks",
        "record_ids": ["tasks/1"],
        "reason": "update",
        "result_ids": ["tasks/1"],
        "coalesced": false
      }
    ]
  }
}

