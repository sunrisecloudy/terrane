{
  "case": "min_version_higher_than_client_refuses",
  "description": "The client knows the feature but only at a lower version than the required min, so the install is refused stating what the client has.",
  "client_features": [
    { "feature_id": "app", "version": "1.0.0" },
    { "feature_id": "ctx.db.query", "version": "1.0.0" }
  ],
  "manifest_compatibility": {
    "required_features": [
      { "feature_id": "ctx.db.query", "min_version": "2.0.0" }
    ]
  },
  "expect": {
    "decision": "refuse",
    "unsupported_feature_ids": ["ctx.db.query"],
    "message_contains": ["ctx.db.query", "required >= 2.0.0", "client has 1.0.0"]
  }
}
