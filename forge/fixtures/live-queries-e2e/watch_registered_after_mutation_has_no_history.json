{
  "case": "watch_registered_after_mutation_has_no_history",
  "description": "A watch registered after a mutation sees the current result but is not notified for past mutations.",
  "given": {
    "records": [],
    "watches": [],
    "next_version": 12
  },
  "when": {
    "steps": [
      {"op": "mutation", "mutation": {"op": "insert", "collection": "tasks", "id": "tasks/1", "fields": {"title": "Already happened", "done": false}}},
      {"op": "watch", "watch_id": "watch:tasks-open", "query": {"from": "tasks", "where": ["done", "=", false], "orderBy": ["id", "asc"]}}
    ]
  },
  "expect": {
    "dirty_sets": [
      {"version": 12, "collections": {"tasks": ["tasks/1"]}}
    ],
    "watch_initial_result_ids": {"watch:tasks-open": ["tasks/1"]},
    "notifications": [],
    "next_version": 13
  }
}
