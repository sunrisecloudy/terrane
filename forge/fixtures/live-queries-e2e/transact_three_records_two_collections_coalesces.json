{
  "case": "transact_three_records_two_collections_coalesces",
  "description": "A transaction touching three records in two collections emits at most one coalesced notification per affected watch.",
  "given": {
    "records": [
      {"collection": "tasks", "id": "tasks/1", "fields": {"title": "Existing", "done": false}, "deleted": false},
      {"collection": "notes", "id": "notes/1", "fields": {"body": "Remove me"}, "deleted": false}
    ],
    "watches": [
      {"watch_id": "watch:tasks-all", "query": {"from": "tasks", "orderBy": ["id", "asc"]}},
      {"watch_id": "watch:notes-all", "query": {"from": "notes", "orderBy": ["id", "asc"]}}
    ],
    "next_version": 20
  },
  "when": {
    "mutation": {
      "op": "transact",
      "items": [
        {"op": "patch", "collection": "tasks", "id": "tasks/1", "fields": {"title": "Updated"}},
        {"op": "insert", "collection": "tasks", "id": "tasks/2", "fields": {"title": "New", "done": false}},
        {"op": "delete", "collection": "notes", "id": "notes/1"}
      ]
    }
  },
  "expect": {
    "dirty_set": {"version": 20, "collections": {"notes": ["notes/1"], "tasks": ["tasks/1", "tasks/2"]}},
    "notifications": [
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-all",
        "version": 20,
        "collection": "tasks",
        "record_ids": ["tasks/1", "tasks/2"],
        "reason": "mixed",
        "result_ids": ["tasks/1", "tasks/2"],
        "coalesced": true
      },
      {
        "type": "db.watch.notification",
        "watch_id": "watch:notes-all",
        "version": 20,
        "collection": "notes",
        "record_ids": ["notes/1"],
        "reason": "delete",
        "result_ids": [],
        "coalesced": false
      }
    ],
    "reason_scope": "per watched collection",
    "max_notifications_per_watch_per_transaction": 1
  }
}
