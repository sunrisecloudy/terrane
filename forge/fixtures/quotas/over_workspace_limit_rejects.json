{
  "case": "over_workspace_limit_rejects",
  "prd": "DL-22",
  "describe": "a write whose projected total exceeds the workspace limit is REJECTED with a typed ResourceLimitExceeded suggesting compaction/cleanup/export — never a deletion",
  "assert": {
    "kind": "decision",
    "usage": {
      "workspace_total_bytes": 900,
      "per_applet": [{ "applet": "tasks", "collections_bytes": 900 }],
      "per_category": { "attachments": 0, "run_logs": 0, "retained_chunks": 900, "snapshots": 0, "cache": 0 }
    },
    "policy": { "workspace_limit": 1000, "per_applet_limit": 100000, "retained_chunks_cap": 100000, "approaching_threshold": 0.8 },
    "category": "retained_chunks",
    "applet": "tasks",
    "write_bytes": 200,
    "expect": {
      "decision": "over_quota",
      "scope": "workspace",
      "projected": 1100,
      "limit": 1000,
      "error_code": "ResourceLimitExceeded",
      "error_contains": "no data was deleted"
    }
  }
}
