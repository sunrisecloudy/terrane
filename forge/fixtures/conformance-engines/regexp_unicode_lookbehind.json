    "body": "export async function main(_ctx, _input) {\n  const price = '$1234'.match(/(?<=\\$)\\d+/u)[0];\n  const letters = [...'a1b2c3'.matchAll(/\\p{L}/gu)].map(m => m[0]);\n  const named = 'jane-doe'.match(/(?<first>\\w+)-(?<last>\\w+)/).groups;\n  const split = 'a,b;c d'.split(/[,;\\s]/u);\n  return { ok: true, value: { price, letters, first: named.first, last: named.last, split } };\n}\n",
