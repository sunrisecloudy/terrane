    "body": "export async function main(_ctx, _input) {\n  const o = {};\n  o.first = 1; o['100'] = 2; o.second = 3; o['5'] = 4; o['2'] = 5; o.third = 6;\n  const keys = Object.keys(o);\n  const forIn = []; for (const k in o) forIn.push(k);\n  const spread = Object.keys({ ...o });\n  return { ok: true, value: { keys, forIn, spread, entries: Object.entries(o) } };\n}\n",
