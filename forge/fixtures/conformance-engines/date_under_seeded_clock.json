    "body": "export async function main(ctx, _input) {\n  const t = ctx.time.now();\n  const d = new Date(t);\n  return { ok: true, value: {\n    iso: d.toISOString(),\n    year: d.getUTCFullYear(),\n    month: d.getUTCMonth(),\n    epochMs: d.getTime(),\n    plusDayIso: new Date(t + 86400000).toISOString()\n  } };\n}\n",
