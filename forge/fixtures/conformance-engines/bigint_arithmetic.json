  "source": {
    "body": "export async function main(_ctx, _input) {\n  const a = 9007199254740993n;\n  const b = a * 1000n + 7n;\n  const wrapU = BigInt.asUintN(8, 257n);\n  const wrapI = BigInt.asIntN(8, 200n);\n  const pow = 2n ** 64n;\n  return { ok: true, value: {\n    sum: String(a + 1n), product: String(b), wrapU: String(wrapU),\n    wrapI: String(wrapI), pow: String(pow), cmp: a > 9007199254740992n\n  } };\n}\n",
