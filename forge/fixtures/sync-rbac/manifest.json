{
  "suite": "sync-rbac-validation-vectors",
  "version": 1,
  "spec": "../../spec/sync-rbac.md",
  "prd": ["SS-7", "SS-9", "SC-9", "SC-10", "SC-11", "SC-12"],
  "scope": "Semantic validation vectors for authorizing remote sync apply before CRDT import.",
  "trusted_authority": "receiving_workspace_membership",
  "count": 10,
  "cases": [
    {
      "case": "editor_granted_collection_insert_applied",
      "file": "editor_granted_collection_insert_applied.json",
      "expect": "applied"
    },
    {
      "case": "viewer_remote_write_rejected",
      "file": "viewer_remote_write_rejected.json",
      "expect": "permission_denied"
    },
    {
      "case": "editor_outside_db_write_scope_rejected",
      "file": "editor_outside_db_write_scope_rejected.json",
      "expect": "permission_denied"
    },
    {
      "case": "owner_wildcard_write_applied",
      "file": "owner_wildcard_write_applied.json",
      "expect": "applied"
    },
    {
      "case": "runner_delete_rejected",
      "file": "runner_delete_rejected.json",
      "expect": "permission_denied"
    },
    {
      "case": "viewer_delete_with_claimed_grant_rejected",
      "file": "viewer_delete_with_claimed_grant_rejected.json",
      "expect": "permission_denied"
    },
    {
      "case": "maintainer_schema_change_applied",
      "file": "maintainer_schema_change_applied.json",
      "expect": "applied"
    },
    {
      "case": "editor_schema_change_rejected",
      "file": "editor_schema_change_rejected.json",
      "expect": "permission_denied"
    },
    {
      "case": "authorized_concurrent_edit_applied_converges",
      "file": "authorized_concurrent_edit_applied_converges.json",
      "expect": "applied"
    },
    {
      "case": "role_claim_exceeds_trusted_grant_rejected",
      "file": "role_claim_exceeds_trusted_grant_rejected.json",
      "expect": "permission_denied"
    }
  ]
}
