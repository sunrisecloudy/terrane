{
  "case": "nested_allowed_read",
  "grant": {
    "files": {
      "read": [
        {
          "handle": "workspace_data",
          "path_glob": "data/**/*.json",
          "max_bytes": 65536,
          "content_types": [
            "application/json"
          ]
        }
      ],
      "write": []
    }
  },
  "resolved_handles": {
    "workspace_data": {
      "root": "<applet-sandbox>/workspace_data",
      "kind": "per_applet_root"
    }
  },
  "filesystem": {
    "files": [
      {
        "path": "data/reports/2026/status.json",
        "bytes_base64": "bmVzdGVkIHBheWxvYWQ=",
        "content_type": "application/json"
      }
    ],
    "symlinks": []
  },
  "op": {
    "kind": "read",
    "handle": "workspace_data",
    "path": "data/reports/2026/status.json",
    "encoding": "base64"
  },
  "expect": "allowed",
  "response": {
    "path": "data/reports/2026/status.json",
    "bytes_base64": "bmVzdGVkIHBheWxvYWQ=",
    "size": 14,
    "content_type": "application/json"
  },
  "trace_expectation": {
    "method": "files.read",
    "replay_touches_filesystem": false
  },
  "reason": "a ** glob is required for nested directories and permits this path"
}
