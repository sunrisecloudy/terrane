{
  "case": "deterministic_replay_recorded_read",
  "grant": {
    "files": {
      "read": [
        {
          "handle": "workspace_data",
          "path_glob": "cache/*.txt",
          "max_bytes": 65536,
          "content_types": [
            "text/plain"
          ]
        }
      ],
      "write": []
    }
  },
  "resolved_handles": {
    "workspace_data": {
      "root": "<applet-sandbox>/workspace_data",
      "kind": "per_applet_root"
    }
  },
  "record_phase": {
    "filesystem": {
      "files": [
        {
          "path": "cache/value.txt",
          "bytes_base64": "cmVjb3JkZWQgYnl0ZXMgdjE=",
          "content_type": "text/plain"
        }
      ],
      "symlinks": []
    },
    "op": {
      "kind": "read",
      "handle": "workspace_data",
      "path": "cache/value.txt",
      "encoding": "base64"
    },
    "recorded_call": {
      "method": "files.read",
      "args": [
        {
          "handle": "workspace_data",
          "path": "cache/value.txt",
          "encoding": "base64"
        }
      ],
      "response": {
        "path": "cache/value.txt",
        "bytes_base64": "cmVjb3JkZWQgYnl0ZXMgdjE=",
        "size": 17,
        "content_type": "text/plain"
      }
    }
  },
  "replay_phase": {
    "filesystem": {
      "files": [],
      "symlinks": []
    },
    "expect_response": {
      "path": "cache/value.txt",
      "bytes_base64": "cmVjb3JkZWQgYnl0ZXMgdjE=",
      "size": 17,
      "content_type": "text/plain"
    },
    "live_filesystem_touched": false
  },
  "expect": "replay_byte_identical",
  "reason": "replay serves the recorded file bytes even if the live file is absent"
}
