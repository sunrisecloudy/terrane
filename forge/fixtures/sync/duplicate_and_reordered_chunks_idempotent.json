{
  "version": 1,
  "case": "duplicate_and_reordered_chunks_idempotent",
  "coverage": ["SS-2", "DL-6", "duplicate_delivery", "reordered_delivery"],
  "peer_a_id": 101,
  "peer_b_id": 202,
  "seed": [],
  "peer_a": [
    {
      "op": "insert",
      "collection": "tasks",
      "id": "t1",
      "fields": {
        "done": false,
        "title": "a"
      }
    },
    {
      "op": "patch",
      "collection": "tasks",
      "id": "t1",
      "fields": {
        "done": true
      }
    }
  ],
  "peer_b": [],
  "sync": {
    "directions": ["a_to_b"],
    "frontier": "exchanged_chunk_id_set_per_doc",
    "duplicate_chunks": true,
    "reorder_chunks": true
  },
  "expect_converged": {
    "tasks": [
      {
        "id": "t1",
        "fields": {
          "done": true,
          "title": "a"
        }
      }
    ]
  },
  "assertions": [
    "peer_a_projection_equals_peer_b_projection",
    "projection_equals_expect_converged",
    "duplicate_chunks_are_idempotent",
    "reordered_chunks_converge"
  ]
}
