{
  "version": 1,
  "case": "delete_on_one_peer",
  "coverage": ["SS-1", "SS-2", "DL-4", "record_delete"],
  "peer_a_id": 101,
  "peer_b_id": 202,
  "seed": [
    {
      "op": "insert",
      "collection": "tasks",
      "id": "t1",
      "fields": {
        "title": "remove me"
      }
    },
    {
      "op": "insert",
      "collection": "tasks",
      "id": "t2",
      "fields": {
        "status": "open",
        "title": "keep me"
      }
    }
  ],
  "seed_mode": "shared_history",
  "peer_a": [
    {
      "op": "delete",
      "collection": "tasks",
      "id": "t1"
    }
  ],
  "peer_b": [
    {
      "op": "patch",
      "collection": "tasks",
      "id": "t2",
      "fields": {
        "status": "done"
      }
    }
  ],
  "sync": {
    "directions": ["a_to_b", "b_to_a"],
    "frontier": "exchanged_chunk_id_set_per_doc",
    "duplicate_chunks": false,
    "reorder_chunks": false
  },
  "expect_converged": {
    "tasks": [
      {
        "id": "t2",
        "fields": {
          "status": "done",
          "title": "keep me"
        }
      }
    ]
  },
  "expect_deleted_ids": ["tasks/t1"],
  "assertions": [
    "peer_a_projection_equals_peer_b_projection",
    "projection_equals_expect_converged",
    "deleted_ids_absent_from_visible_projection"
  ]
}
