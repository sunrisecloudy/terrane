{
  "case": "literal_authorization_header_denied",
  "secrets": {},
  "allowlist": [
    {
      "method": "GET",
      "url": "https://api.weather.example/*",
      "allow_secret_headers": [
        "Authorization"
      ]
    }
  ],
  "request": {
    "method": "GET",
    "url": "https://api.weather.example/now",
    "headers": {
      "Authorization": "Bearer abc123"
    }
  },
  "expect": "deny",
  "expected_error_code": "PermissionDenied",
  "client_must_not_receive_request": true,
  "trace_must_not_contain": [
    "Bearer abc123"
  ],
  "reason": "literal secret-like headers are rejected; applets must use the secret_ref object so plaintext never enters the trace"
}
