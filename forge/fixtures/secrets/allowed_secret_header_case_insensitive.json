{
  "case": "allowed_secret_header_case_insensitive",
  "secrets": {
    "secret_weather": "Bearer abc123"
  },
  "allowlist": [
    {
      "method": "GET",
      "url": "https://api.weather.example/*",
      "allow_secret_headers": [
        "authorization"
      ]
    }
  ],
  "request": {
    "method": "GET",
    "url": "https://api.weather.example/now",
    "headers": {
      "Authorization": {
        "secret_ref": "secret_weather"
      }
    }
  },
  "expect": "injected",
  "injected_header": {
    "Authorization": "Bearer abc123"
  },
  "trace_expectation": {
    "must_not_contain": [
      "Bearer abc123"
    ],
    "replay_requires_secret_store": false
  },
  "reason": "allow_secret_headers comparison is case-insensitive"
}
