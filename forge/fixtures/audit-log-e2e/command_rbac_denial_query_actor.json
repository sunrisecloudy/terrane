{
  "case": "command_rbac_denial_query_actor",
  "description": "A command RBAC denial is persisted and queryable by actor.",
  "given": {
    "next_seq": 10,
    "logical_time_start": 2000,
    "audit_rows": [],
    "actor": {"actor_id": "actor-auditor-1", "role": "auditor"}
  },
  "when": {
    "producer": "command-rbac",
    "command": "runtime.run",
    "resource": {"applet_id": "applet.notes"},
    "decision": "deny"
  },
  "expect": {
    "audit_rows_appended": [
      {
        "audit_id": "audit-000010",
        "seq": 10,
        "logical_time": 2001,
        "producer": "command-rbac",
        "action": "command.runtime.run",
        "decision": "deny",
        "actor_id": "actor-auditor-1",
        "resource_type": "command",
        "resource_id": "runtime.run",
        "applet_id": "applet.notes",
        "reason": "auditor is not permitted to run applet code",
        "metadata": {
          "role": "Auditor",
          "command": "runtime.run",
          "applet_id": "applet.notes"
        }
      }
    ],
    "query": {
      "where": {"actor_id": "actor-auditor-1"},
      "order_by": ["seq", "asc"],
      "result_audit_ids": ["audit-000010"]
    }
  }
}
