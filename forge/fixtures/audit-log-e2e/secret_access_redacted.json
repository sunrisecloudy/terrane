{
  "case": "secret_access_redacted",
  "description": "A secret access attempt persists the secret_ref id and decision but never the resolved secret value.",
  "given": {
    "next_seq": 30,
    "logical_time_start": 4000,
    "audit_rows": [],
    "secret_store": {"secret_weather": "Bearer abc123"}
  },
  "when": {
    "producer": "secrets",
    "source_fixture": "../secrets/allowed_secret_header_injected.json",
    "operation": {
      "actor_id": "actor-runner-1",
      "applet_id": "app.weather",
      "secret_ref": "secret_weather",
      "target": {"method": "GET", "host": "api.weather.example", "header": "Authorization"}
    }
  },
  "expect": {
    "audit_rows_appended": [
      {
        "audit_id": "audit-000030",
        "seq": 30,
        "logical_time": 4001,
        "producer": "secrets",
        "action": "secret.use",
        "decision": "allow",
        "actor_id": "actor-runner-1",
        "resource_type": "secret",
        "resource_id": "secret_weather",
        "applet_id": "app.weather",
        "reason": "secret_ref injected into allowlisted header",
        "metadata": {
          "secret_ref": "secret_weather",
          "target_host": "api.weather.example",
          "target_header": "Authorization",
          "value_redacted": true
        }
      }
    ],
    "query": {
      "where": {"action": "secret.use"},
      "order_by": ["seq", "asc"],
      "result_audit_ids": ["audit-000030"]
    },
    "must_not_contain": ["Bearer abc123", "abc123"],
    "redaction": "secret values never persist in audit rows"
  }
}
