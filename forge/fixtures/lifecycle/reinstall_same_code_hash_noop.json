{
  "case": "reinstall_same_code_hash_noop",
  "given": {
    "active_applet": {
      "applet_id": "applet.todo",
      "install_generation": 1,
      "version": 1,
      "state": "enabled",
      "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
      "manifest_hash": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "sources_hash": "sha256:cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc"
    },
    "versions": [
      {
        "version": 1,
        "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "status": "active"
      }
    ]
  },
  "when": {
    "command": "applet.install",
    "payload": {
      "applet_id": "applet.todo",
      "manifest_hash": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa",
      "sources_hash": "sha256:cccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccccc",
      "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111"
    }
  },
  "expect": {
    "response": {
      "applet_id": "applet.todo",
      "install_generation": 1,
      "version": 1,
      "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
      "idempotent": true
    },
    "active_applet": {
      "install_generation": 1,
      "version": 1,
      "state": "enabled",
      "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111"
    },
    "versions": [
      {
        "version": 1,
        "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "status": "active"
      }
    ],
    "no_new_version": true,
    "events": [
      {
        "kind": "applet.install.noop",
        "applet_id": "applet.todo",
        "version": 1,
        "reason": "same_manifest_and_code_hash"
      }
    ]
  }
}
