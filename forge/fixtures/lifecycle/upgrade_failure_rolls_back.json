{
  "case": "upgrade_failure_rolls_back",
  "given": {
    "active_applet": {
      "applet_id": "applet.todo",
      "install_generation": 1,
      "version": 1,
      "state": "enabled",
      "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
      "manifest_hash": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    },
    "versions": [
      {
        "version": 1,
        "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "status": "active"
      }
    ],
    "records": [
      {
        "collection": "tasks",
        "id": "tasks/1",
        "owner_applet_id": "applet.todo",
        "fields": {
          "title": "existing"
        },
        "deleted": false
      }
    ]
  },
  "when": {
    "command": "applet.upgrade",
    "payload": {
      "applet_id": "applet.todo",
      "manifest_hash": "sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
      "sources_hash": "sha256:eeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeeee",
      "code_hash": "sha256:3333333333333333333333333333333333333333333333333333333333333333",
      "simulate_failure_stage": "schema.apply_change"
    }
  },
  "expect": {
    "accepted": false,
    "error": {
      "code": "lifecycle.upgrade_failed",
      "message_contains": "schema.apply_change"
    },
    "active_applet": {
      "version": 1,
      "state": "enabled",
      "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
      "manifest_hash": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
    },
    "versions": [
      {
        "version": 1,
        "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "status": "active"
      }
    ],
    "rollback": {
      "no_version_2_created": true,
      "records_unchanged": true,
      "schema_unchanged": true,
      "active_pointer_unchanged": true
    },
    "events": [
      {
        "kind": "applet.upgrade.rejected",
        "active_version": 1,
        "error_code": "lifecycle.upgrade_failed"
      }
    ]
  }
}
