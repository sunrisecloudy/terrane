{
  "case": "reenable_resumes_dispatch",
  "given": {
    "active_applet": {
      "applet_id": "applet.todo",
      "install_generation": 1,
      "version": 1,
      "state": "suspended",
      "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111"
    },
    "current_tree": {
      "type": "Button",
      "testId": "resume-add-task",
      "label": "Add task",
      "onTap": "todo.add"
    }
  },
  "when": {
    "ops": [
      {
        "command": "applet.enable",
        "payload": {
          "applet_id": "applet.todo"
        }
      },
      {
        "command": "ui.dispatch_event",
        "payload": {
          "applet_id": "applet.todo",
          "action": "todo.add",
          "event_type": "tap",
          "payload": {}
        }
      }
    ]
  },
  "expect": {
    "active_applet": {
      "state": "enabled",
      "version": 1
    },
    "dispatch": {
      "accepted": true,
      "handler_invoked": true,
      "patches": [
        {
          "op": "replace",
          "path": "/label",
          "value": "Task added"
        }
      ]
    },
    "events": [
      {"kind": "applet.enabled", "state_before": "suspended", "state_after": "enabled"},
      {"kind": "ui.event.dispatched", "action": "todo.add"}
    ]
  }
}
