{
  "id": "api-dashboard",
  "name": "API Dashboard",
  "version": "0.1.0",
  "runtimeVersion": "0.1.0",
  "entry": "index.html",
  "description": "Network request demo with response table, tiny chart, and saved endpoint history.",
  "permissions": [
    "network.request",
    "storage.read",
    "storage.write",
    "notification.toast",
    "app.log"
  ],
  "storagePrefix": "api-dashboard:",
  "dataVersion": 1,
  "capabilities": {
    "required": [
      "network.request",
      "storage.read",
      "storage.write"
    ],
    "optional": [
      "notification.toast",
      "app.log"
    ]
  },
  "resourceBudget": {
    "maxDomNodes": 2000,
    "maxStorageBytes": 5242880,
    "maxBridgeCallsPerMinute": 600,
    "maxNetworkRequestsPerMinute": 60,
    "maxTimers": 64,
    "maxLogLinesPerMinute": 120,
    "maxPackageBytes": 1048576,
    "maxFileBytes": 524288
  },
  "networkPolicy": {
    "allow": [
      {
        "origin": "https://api.example.com",
        "methods": [
          "GET",
          "POST"
        ],
        "allowedHeaders": [
          "authorization",
          "content-type"
        ],
        "maxRequestBytes": 65536,
        "maxResponseBytes": 1048576,
        "timeoutMs": 10000
      }
    ]
  },
  "trust": {
    "level": "bundled",
    "requiresUserApproval": false
  },
  "compatibility": {
    "mode": "strict",
    "minimumRuntimeVersion": "0.1.0"
  },
  "authorId": "example-fixture"
}
