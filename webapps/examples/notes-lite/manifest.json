{
  "id": "notes-lite",
  "name": "Notes Lite",
  "version": "0.1.0",
  "runtimeVersion": "0.1.0",
  "entry": "index.html",
  "description": "Create, search, edit, and delete notes using the storage bridge.",
  "permissions": [
    "storage.read",
    "storage.write",
    "notification.toast",
    "app.log"
  ],
  "storagePrefix": "notes-lite:",
  "dataVersion": 1,
  "capabilities": {
    "required": [
      "storage.read",
      "storage.write"
    ],
    "optional": [
      "notification.toast",
      "app.log"
    ]
  },
  "resourceBudget": {
    "maxDomNodes": 2000,
    "maxStorageBytes": 5242880,
    "maxBridgeCallsPerMinute": 600,
    "maxNetworkRequestsPerMinute": 60,
    "maxTimers": 64,
    "maxLogLinesPerMinute": 120,
    "maxPackageBytes": 1048576,
    "maxFileBytes": 524288
  },
  "networkPolicy": {
    "allow": []
  },
  "trust": {
    "level": "bundled",
    "requiresUserApproval": false
  },
  "compatibility": {
    "mode": "strict",
    "minimumRuntimeVersion": "0.1.0"
  },
  "authorId": "example-fixture"
}
