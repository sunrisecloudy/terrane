{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://terrane.local/forge/data/control-response-schema.json",
  "title": "DevControlPlaneResponse",
  "type": "object",
  "required": ["ok", "diagnostics"],
  "additionalProperties": false,
  "properties": {
    "ok": { "type": "boolean" },
    "result": { "type": "object" },
    "error": {
      "type": "object",
      "required": ["code", "message", "details"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    },
    "diagnostics": {
      "type": "object",
      "required": ["target", "sessionId", "timestamp"],
      "additionalProperties": true,
      "properties": {
        "target": { "type": "string" },
        "sessionId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "oneOf": [
    { "required": ["ok", "result", "diagnostics"], "properties": { "ok": { "const": true } } },
    { "required": ["ok", "error", "diagnostics"], "properties": { "ok": { "const": false } } }
  ]
}