{
  "case": "different_filters_targeted_notifications",
  "description": "Two watches on the same collection with different filters are notified only for dirty ids that may change each result set.",
  "given": {
    "records": [
      {"collection": "tasks", "id": "tasks/1", "fields": {"title": "Open low", "done": false, "priority": "low"}, "deleted": false},
      {"collection": "tasks", "id": "tasks/2", "fields": {"title": "Done low", "done": true, "priority": "low"}, "deleted": false}
    ],
    "watches": [
      {"watch_id": "watch:tasks-open", "query": {"from": "tasks", "where": ["done", "=", false], "orderBy": ["id", "asc"]}},
      {"watch_id": "watch:tasks-high", "query": {"from": "tasks", "where": ["priority", "=", "high"], "orderBy": ["id", "asc"]}}
    ],
    "next_version": 7
  },
  "when": {
    "mutation": {
      "op": "transact",
      "items": [
        {"op": "patch", "collection": "tasks", "id": "tasks/1", "fields": {"done": true}},
        {"op": "patch", "collection": "tasks", "id": "tasks/2", "fields": {"priority": "high"}}
      ]
    }
  },
  "expect": {
    "dirty_set": {"version": 7, "collections": {"tasks": ["tasks/1", "tasks/2"]}},
    "notifications": [
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-open",
        "version": 7,
        "collection": "tasks",
        "record_ids": ["tasks/1"],
        "reason": "update",
        "result_ids": [],
        "coalesced": false
      },
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-high",
        "version": 7,
        "collection": "tasks",
        "record_ids": ["tasks/2"],
        "reason": "update",
        "result_ids": ["tasks/2"],
        "coalesced": false
      }
    ],
    "notification_order": "watch registration order",
    "non_matching_dirty_ids_omitted": true
  }
}
