{
  "case": "replay_session_notifications_byte_identical",
  "description": "A recorded session containing mutations plus watch notifications replays the notification stream byte-identically without live hooks.",
  "given": {
    "records": [],
    "watches": [
      {"watch_id": "watch:tasks-open", "query": {"from": "tasks", "where": ["done", "=", false], "orderBy": ["id", "asc"]}}
    ],
    "next_version": 50
  },
  "when": {
    "recorded_session": [
      {"op": "mutation", "mutation": {"op": "insert", "collection": "tasks", "id": "tasks/1", "fields": {"title": "Replay A", "done": false}}},
      {"op": "mutation", "mutation": {"op": "patch", "collection": "tasks", "id": "tasks/1", "fields": {"done": true}}}
    ],
    "replay_mode": true
  },
  "expect": {
    "recorded_calls": [
      {
        "method": "db.watch.notification",
        "args": {
          "watch_id": "watch:tasks-open",
          "version": 50,
          "collection": "tasks",
          "record_ids": ["tasks/1"],
          "reason": "insert",
          "result_ids": ["tasks/1"],
          "coalesced": false
        },
        "result": {"delivered": true}
      },
      {
        "method": "db.watch.notification",
        "args": {
          "watch_id": "watch:tasks-open",
          "version": 51,
          "collection": "tasks",
          "record_ids": ["tasks/1"],
          "reason": "update",
          "result_ids": [],
          "coalesced": false
        },
        "result": {"delivered": true}
      }
    ],
    "notifications": [
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-open",
        "version": 50,
        "collection": "tasks",
        "record_ids": ["tasks/1"],
        "reason": "insert",
        "result_ids": ["tasks/1"],
        "coalesced": false
      },
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-open",
        "version": 51,
        "collection": "tasks",
        "record_ids": ["tasks/1"],
        "reason": "update",
        "result_ids": [],
        "coalesced": false
      }
    ],
    "replay": {
      "open_update_hooks": false,
      "recompute_result_ids": false,
      "byte_identical_notifications": true
    }
  }
}
