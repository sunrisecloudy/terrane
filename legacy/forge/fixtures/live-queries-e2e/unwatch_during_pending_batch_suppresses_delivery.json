{
  "case": "unwatch_during_pending_batch_suppresses_delivery",
  "description": "If db.unwatch commits before a pending batch is delivered, the watch receives no notification from that batch.",
  "given": {
    "records": [
      {"collection": "tasks", "id": "tasks/1", "fields": {"title": "Existing", "done": false}, "deleted": false}
    ],
    "watches": [
      {"watch_id": "watch:tasks-open", "query": {"from": "tasks", "where": ["done", "=", false], "orderBy": ["id", "asc"]}}
    ],
    "next_version": 9
  },
  "when": {
    "batch": [
      {"op": "mutation", "mutation": {"op": "insert", "collection": "tasks", "id": "tasks/2", "fields": {"title": "Queued", "done": false}}},
      {"op": "unwatch", "watch_id": "watch:tasks-open", "timing": "before_delivery_flush"}
    ]
  },
  "expect": {
    "dirty_set": {"version": 9, "collections": {"tasks": ["tasks/2"]}},
    "active_watches": [],
    "notifications": [],
    "pending_notifications_dropped": ["watch:tasks-open"]
  }
}
