{
  "case": "reentrant_callback_mutation_queued_next_turn",
  "description": "A watch callback that triggers a mutation queues that mutation as the next event-loop turn, preventing recursive notification delivery.",
  "decision": "Notification delivery is non-reentrant. Mutations requested by a notification callback are queued after the current delivery batch and receive a later watch version.",
  "given": {
    "records": [],
    "watches": [
      {
        "watch_id": "watch:tasks-all",
        "query": {"from": "tasks", "orderBy": ["id", "asc"]},
        "callback_effect": {"op": "patch", "collection": "tasks", "id": "tasks/1", "fields": {"title": "from callback"}}
      }
    ],
    "next_version": 70
  },
  "when": {
    "mutation": {"op": "insert", "collection": "tasks", "id": "tasks/1", "fields": {"title": "initial", "done": false}}
  },
  "expect": {
    "notifications": [
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-all",
        "version": 70,
        "collection": "tasks",
        "record_ids": ["tasks/1"],
        "reason": "insert",
        "result_ids": ["tasks/1"],
        "coalesced": false
      },
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-all",
        "version": 71,
        "collection": "tasks",
        "record_ids": ["tasks/1"],
        "reason": "update",
        "result_ids": ["tasks/1"],
        "coalesced": false
      }
    ],
    "event_loop": {
      "recursive_delivery_allowed": false,
      "callback_mutation_timing": "next_turn_after_current_delivery",
      "max_delivery_depth_per_turn": 1
    },
    "dirty_sets": [
      {"version": 70, "collections": {"tasks": ["tasks/1"]}},
      {"version": 71, "collections": {"tasks": ["tasks/1"]}}
    ]
  }
}
