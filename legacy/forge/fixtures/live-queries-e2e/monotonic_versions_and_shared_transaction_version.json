{
  "case": "monotonic_versions_and_shared_transaction_version",
  "description": "Sequential transactions produce strictly increasing versions, while notifications from the SAME transaction share a version. The shared-version transaction is a SINGLE-collection transact observed by TWO watches on that collection (a transact must target one collection — DL-17 multi-collection transact is unsupported, reviews 131/132), so both watches' notifications carry the one transaction version.",
  "given": {
    "records": [],
    "watches": [
      {"watch_id": "watch:tasks-all", "query": {"from": "tasks", "orderBy": ["id", "asc"]}},
      {"watch_id": "watch:tasks-open", "query": {"from": "tasks", "where": ["done", "=", false], "orderBy": ["id", "asc"]}}
    ],
    "next_version": 100
  },
  "when": {
    "transactions": [
      {"mutation": {"op": "insert", "collection": "tasks", "id": "tasks/1", "fields": {"title": "A", "done": true}}},
      {"mutation": {"op": "transact", "items": [
        {"op": "insert", "collection": "tasks", "id": "tasks/2", "fields": {"title": "B", "done": false}},
        {"op": "insert", "collection": "tasks", "id": "tasks/3", "fields": {"title": "C", "done": false}}
      ]}},
      {"mutation": {"op": "patch", "collection": "tasks", "id": "tasks/1", "fields": {"title": "A2"}}}
    ]
  },
  "expect": {
    "notifications": [
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-all",
        "version": 100,
        "collection": "tasks",
        "record_ids": ["tasks/1"],
        "reason": "insert",
        "result_ids": ["tasks/1"],
        "coalesced": false
      },
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-all",
        "version": 101,
        "collection": "tasks",
        "record_ids": ["tasks/2", "tasks/3"],
        "reason": "insert",
        "result_ids": ["tasks/1", "tasks/2", "tasks/3"],
        "coalesced": true
      },
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-open",
        "version": 101,
        "collection": "tasks",
        "record_ids": ["tasks/2", "tasks/3"],
        "reason": "insert",
        "result_ids": ["tasks/2", "tasks/3"],
        "coalesced": true
      },
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-all",
        "version": 102,
        "collection": "tasks",
        "record_ids": ["tasks/1"],
        "reason": "update",
        "result_ids": ["tasks/1", "tasks/2", "tasks/3"],
        "coalesced": false
      }
    ],
    "versions": {
      "strictly_increasing_between_transactions": [100, 101, 102],
      "same_transaction_notifications_share_version": 101
    }
  }
}
