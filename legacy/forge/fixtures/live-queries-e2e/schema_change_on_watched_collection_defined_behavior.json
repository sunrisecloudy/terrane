{
  "case": "schema_change_on_watched_collection_defined_behavior",
  "description": "Watched-collection schema changes have a defined non-notification behavior under v1 additive-only schema rules.",
  "decision": "Additive schema changes do not emit db.watch.notification by themselves and keep existing watches active. A destructive collection drop is not exposed in v1 and is rejected as SchemaCompatibilityError before watch invalidation.",
  "given": {
    "records": [
      {"collection": "tasks", "id": "tasks/1", "fields": {"title": "Keep watching", "done": false}, "deleted": false}
    ],
    "watches": [
      {"watch_id": "watch:tasks-open", "query": {"from": "tasks", "where": ["done", "=", false], "orderBy": ["id", "asc"]}}
    ],
    "schema": {
      "tasks": [
        {"id": "f_title", "name": "title", "type": "Text"},
        {"id": "f_done", "name": "done", "type": "Bool"}
      ]
    },
    "next_version": 37
  },
  "when": {
    "schema_ops": [
      {"op": "add_field", "collection": "tasks", "field": {"id": "f_due", "name": "due", "type": "Text", "required": false}},
      {"op": "drop_collection", "collection": "tasks"}
    ]
  },
  "expect": {
    "schema_results": [
      {"op": "add_field", "result": "accepted", "watch_state": "active"},
      {"op": "drop_collection", "result": "rejected", "error_kind": "SchemaCompatibilityError", "watch_state": "active"}
    ],
    "dirty_set": null,
    "notifications": [],
    "watch_initial_result_ids": {"watch:tasks-open": ["tasks/1"]}
  }
}
