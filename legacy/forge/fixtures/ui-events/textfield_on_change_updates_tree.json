{
  "case": "textfield_on_change_updates_tree",
  "kind": "dispatch",
  "applet": {
    "id": "example.profile",
    "entrypoint": "render",
    "state_model": "name: string"
  },
  "initial_state": {
    "name": ""
  },
  "initial_tree": {
    "type": "Stack",
    "direction": "v",
    "children": [
      {
        "type": "TextField",
        "testId": "name-input",
        "label": "Name",
        "value": "",
        "onChange": "profile.name.change"
      },
      {
        "type": "Text",
        "testId": "name-preview",
        "text": "Hello, stranger"
      }
    ]
  },
  "events": [
    {
      "action": "profile.name.change",
      "event_type": "change",
      "payload": {
        "value": "Ada"
      }
    }
  ],
  "expect": {
    "results": [
      {
        "state": {
          "name": "Ada"
        },
        "patches": [
          {
            "op": "update_prop",
            "path": [
              0
            ],
            "key": "value",
            "value": "Ada"
          },
          {
            "op": "update_text",
            "path": [
              1
            ],
            "value": "Hello, Ada"
          }
        ]
      }
    ],
    "final_tree": {
      "type": "Stack",
      "direction": "v",
      "children": [
        {
          "type": "TextField",
          "testId": "name-input",
          "label": "Name",
          "value": "Ada",
          "onChange": "profile.name.change"
        },
        {
          "type": "Text",
          "testId": "name-preview",
          "text": "Hello, Ada"
        }
      ]
    },
    "deterministic": true
  }
}
