{
  "case": "list_item_toggle_by_stable_key",
  "kind": "dispatch",
  "applet": {
    "id": "example.todo",
    "entrypoint": "render"
  },
  "initial_state": {
    "items": [
      {
        "id": "a",
        "title": "Write PRD",
        "done": false
      },
      {
        "id": "b",
        "title": "Review diff",
        "done": false
      }
    ]
  },
  "initial_tree": {
    "type": "List",
    "testId": "todo-list",
    "items": [
      {
        "type": "Button",
        "id": "a",
        "testId": "todo-a",
        "label": "Write PRD",
        "onTap": "todo.toggle:a"
      },
      {
        "type": "Button",
        "id": "b",
        "testId": "todo-b",
        "label": "Review diff",
        "onTap": "todo.toggle:b"
      }
    ]
  },
  "events": [
    {
      "action": "todo.toggle:b",
      "event_type": "tap",
      "payload": {
        "id": "b"
      }
    }
  ],
  "expect": {
    "addressing": "ActionRef suffix and node id/testId identify the stable list item across re-renders; M0a patch paths remain index based.",
    "results": [
      {
        "state": {
          "items": [
            {
              "id": "a",
              "title": "Write PRD",
              "done": false
            },
            {
              "id": "b",
              "title": "Review diff",
              "done": true
            }
          ]
        },
        "patches": [
          {
            "op": "update_prop",
            "path": [
              1
            ],
            "key": "label",
            "value": "Done: Review diff"
          }
        ]
      }
    ],
    "final_tree": {
      "type": "List",
      "testId": "todo-list",
      "items": [
        {
          "type": "Button",
          "id": "a",
          "testId": "todo-a",
          "label": "Write PRD",
          "onTap": "todo.toggle:a"
        },
        {
          "type": "Button",
          "id": "b",
          "testId": "todo-b",
          "label": "Done: Review diff",
          "onTap": "todo.toggle:b"
        }
      ]
    }
  }
}
