{
  "case": "sequential_events_accumulate_state",
  "kind": "dispatch",
  "applet": {
    "id": "example.counter",
    "entrypoint": "render",
    "state_model": "count: number"
  },
  "initial_state": {
    "count": 0
  },
  "initial_tree": {
    "type": "Stack",
    "direction": "v",
    "children": [
      {
        "type": "Text",
        "testId": "count-label",
        "text": "0"
      },
      {
        "type": "Button",
        "testId": "increment-button",
        "label": "Increment",
        "onTap": "counter.increment"
      }
    ]
  },
  "events": [
    {
      "action": "counter.increment",
      "event_type": "tap",
      "payload": {}
    },
    {
      "action": "counter.increment",
      "event_type": "tap",
      "payload": {}
    }
  ],
  "expect": {
    "results": [
      {
        "state": {
          "count": 1
        },
        "patches": [
          {
            "op": "update_text",
            "path": [
              0
            ],
            "value": "1"
          }
        ]
      },
      {
        "state": {
          "count": 2
        },
        "patches": [
          {
            "op": "update_text",
            "path": [
              0
            ],
            "value": "2"
          }
        ]
      }
    ],
    "final_tree": {
      "type": "Stack",
      "direction": "v",
      "children": [
        {
          "type": "Text",
          "testId": "count-label",
          "text": "2"
        },
        {
          "type": "Button",
          "testId": "increment-button",
          "label": "Increment",
          "onTap": "counter.increment"
        }
      ]
    },
    "deterministic": true
  }
}
