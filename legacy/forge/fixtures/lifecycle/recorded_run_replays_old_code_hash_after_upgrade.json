{
  "case": "recorded_run_replays_old_code_hash_after_upgrade",
  "given": {
    "active_applet": {
      "applet_id": "applet.todo",
      "install_generation": 1,
      "version": 1,
      "state": "enabled",
      "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111"
    },
    "recorded_runs": [
      {
        "run_id": "run-v1-0001",
        "applet_id": "applet.todo",
        "install_generation": 1,
        "version": 1,
        "code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
        "program_pin": "program/run/run-v1-0001"
      }
    ]
  },
  "when": {
    "ops": [
      {
        "command": "applet.upgrade",
        "payload": {
          "applet_id": "applet.todo",
          "manifest_hash": "sha256:bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb",
          "sources_hash": "sha256:dddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddddd",
          "code_hash": "sha256:2222222222222222222222222222222222222222222222222222222222222222"
        }
      },
      {
        "command": "runtime.replay",
        "payload": {
          "run_id": "run-v1-0001"
        }
      }
    ]
  },
  "expect": {
    "active_applet": {
      "version": 2,
      "code_hash": "sha256:2222222222222222222222222222222222222222222222222222222222222222"
    },
    "replay": {
      "accepted": true,
      "run_id": "run-v1-0001",
      "uses_program_pin": "program/run/run-v1-0001",
      "recorded_version": 1,
      "recorded_code_hash": "sha256:1111111111111111111111111111111111111111111111111111111111111111",
      "does_not_use_active_code_hash": "sha256:2222222222222222222222222222222222222222222222222222222222222222",
      "replays_identically": true
    },
    "events": [
      {"kind": "applet.upgraded", "from_version": 1, "to_version": 2},
      {"kind": "run.replayed", "run_id": "run-v1-0001", "ok": true}
    ]
  }
}
