{
  "version": 1,
  "case": "platform_permission_unavailable",
  "coverage": ["SC-10", "CR-3"],
  "summary": "The host OS has not granted the ui capability (e.g. no display surface), so gate 5 (platform-permission) reports PlatformUnavailable — the capability is absent, not refused.",
  "actor": { "role": "owner" },
  "manifest": {
    "capabilities": { "ui": true },
    "limits": { "max_host_calls": 100 }
  },
  "workspace_policy": { "allowed": ["ui"], "denied": [] },
  "run_profile": { "name": "default", "permitted": ["ui"] },
  "platform": { "granted": [] },
  "request": { "call": "ui" },
  "expect": {
    "decision": "deny",
    "gate": "platform-permission",
    "code": "PlatformUnavailable",
    "reason_contains": "platform permission"
  }
}
