{
  "version": 1,
  "case": "capability_not_in_manifest_denied",
  "coverage": ["SC-10", "SC-8"],
  "summary": "The manifest declares no db capability at all, so gate 3 (manifest) denies with CapabilityRequired even though the workspace/run/platform all permit db.",
  "actor": { "role": "owner" },
  "manifest": {
    "capabilities": { "storage": { "read": ["app/*"], "write": [] } },
    "limits": { "max_host_calls": 100 }
  },
  "workspace_policy": { "allowed": ["db", "storage"], "denied": [] },
  "run_profile": { "name": "default", "permitted": ["db", "storage"] },
  "platform": { "granted": ["db", "storage"] },
  "request": { "call": "db", "op": "read", "collection": "tasks" },
  "expect": {
    "decision": "deny",
    "gate": "manifest",
    "code": "CapabilityRequired",
    "reason_contains": "db"
  }
}
