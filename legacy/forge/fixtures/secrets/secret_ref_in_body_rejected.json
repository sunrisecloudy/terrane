{
  "case": "secret_ref_in_body_rejected",
  "secrets": {
    "secret_weather": "Bearer abc123"
  },
  "allowlist": [
    {
      "method": "POST",
      "url": "https://api.weather.example/*",
      "allow_secret_headers": [
        "Authorization"
      ],
      "request_content_types": [
        "application/json"
      ]
    }
  ],
  "request": {
    "method": "POST",
    "url": "https://api.weather.example/report",
    "content_type": "application/json",
    "body": {
      "token": {
        "secret_ref": "secret_weather"
      }
    }
  },
  "expect": "reject",
  "expected_error_code": "ValidationError",
  "client_must_not_receive_request": true,
  "reason": "M0a only permits secret_ref in header values; putting a secret ref in the request body is a secret-exfil pattern"
}
