{
  "case": "secret_header_not_allowlisted_denied",
  "secrets": {
    "secret_weather": "Bearer abc123"
  },
  "allowlist": [
    {
      "method": "GET",
      "url": "https://api.weather.example/*",
      "allow_secret_headers": []
    }
  ],
  "request": {
    "method": "GET",
    "url": "https://api.weather.example/now",
    "headers": {
      "Authorization": {
        "secret_ref": "secret_weather"
      }
    }
  },
  "expect": "deny",
  "expected_error_code": "PermissionDenied",
  "client_must_not_receive_request": true,
  "reason": "a secret-bearing header is denied unless the matching net rule lists that header in allow_secret_headers"
}
