{
  "case": "benign_request_no_secrets_allowed",
  "secrets": {},
  "allowlist": [
    {
      "method": "GET",
      "url": "https://api.weather.example/*"
    }
  ],
  "request": {
    "method": "GET",
    "url": "https://api.weather.example/public",
    "headers": {
      "Accept": "application/json"
    }
  },
  "expect": "allow",
  "injected_header": {},
  "trace_expectation": {
    "must_not_contain_secret_values": true,
    "replay_requires_secret_store": false
  },
  "reason": "requests without secret refs use normal net policy and do not require SecretStore"
}
