{
  "case": "history_and_restore_deterministic",
  "prd": "DL-20",
  "describe": "history reads are byte-stable and a restore replays deterministically (no wall clock)",
  "collection": "notes",
  "record": "n1",
  "seed": [
    { "op": "insert", "id": "n1", "fields": { "body": "first" }, "logical_at": 1 },
    { "op": "update", "id": "n1", "fields": { "body": "second" }, "logical_at": 2 }
  ],
  "assert": {
    "kind": "deterministic",
    "to_version": 1,
    "restored_logical_at": 3,
    "expect_new_version": 3,
    "expect_current_fields": { "body": "first" }
  }
}
