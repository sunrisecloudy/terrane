{
  "case": "restore_keeps_prior_versions_intact",
  "prd": "DL-20",
  "describe": "after restore all prior versions remain reconstructable and the feed only grew",
  "collection": "tasks",
  "record": "t1",
  "seed": [
    { "op": "insert", "id": "t1", "fields": { "title": "A" }, "logical_at": 1 },
    { "op": "patch",  "id": "t1", "fields": { "title": "B" }, "logical_at": 2 },
    { "op": "patch",  "id": "t1", "fields": { "title": "C" }, "logical_at": 3 }
  ],
  "assert": {
    "kind": "restore",
    "to_version": 2,
    "restored_logical_at": 4,
    "expect_new_version": 4,
    "expect_current_fields": { "title": "B" },
    "expect_prior_intact": [
      { "version": 1, "state_fields": { "title": "A" } },
      { "version": 2, "state_fields": { "title": "B" } },
      { "version": 3, "state_fields": { "title": "C" } }
    ],
    "expect_history_grew_by": 1,
    "expect_history_len": 4
  }
}
