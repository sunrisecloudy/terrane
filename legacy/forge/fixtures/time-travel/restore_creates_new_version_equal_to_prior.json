{
  "case": "restore_creates_new_version_equal_to_prior",
  "prd": "DL-20",
  "describe": "restore appends a NEW version whose state equals a prior version",
  "collection": "tasks",
  "record": "t1",
  "seed": [
    { "op": "insert", "id": "t1", "fields": { "title": "A" }, "logical_at": 1 },
    { "op": "patch",  "id": "t1", "fields": { "title": "B" }, "logical_at": 2 },
    { "op": "patch",  "id": "t1", "fields": { "title": "C" }, "logical_at": 3 }
  ],
  "assert": {
    "kind": "restore",
    "to_version": 1,
    "restored_logical_at": 4,
    "expect_new_version": 4,
    "expect_current_fields": { "title": "A" }
  }
}
