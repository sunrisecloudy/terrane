{
  "case": "history_scoped_to_named_record",
  "prd": "DL-20",
  "describe": "a sibling record's changes never leak into another record's feed",
  "collection": "tasks",
  "record": "t1",
  "seed": [
    { "op": "insert", "id": "t1", "fields": { "title": "A" }, "logical_at": 1 },
    { "op": "insert", "id": "t2", "fields": { "title": "X" }, "logical_at": 2 },
    { "op": "patch",  "id": "t1", "fields": { "title": "B" }, "logical_at": 3 }
  ],
  "assert": {
    "kind": "history",
    "entries": [
      { "version": 1, "actor": "local", "logical_at": 1, "op_kind": "record.insert", "state_fields": { "title": "A" } },
      { "version": 3, "actor": "local", "logical_at": 3, "op_kind": "record.patch",  "state_fields": { "title": "B" } }
    ]
  }
}
