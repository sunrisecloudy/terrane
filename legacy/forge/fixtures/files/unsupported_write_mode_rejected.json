{
  "case": "unsupported_write_mode_rejected",
  "grant": {
    "files": {
      "read": [],
      "write": [
        {
          "handle": "workspace_data",
          "path_glob": "drafts/*.txt",
          "max_bytes": 65536,
          "content_types": [
            "text/plain"
          ]
        }
      ]
    }
  },
  "resolved_handles": {
    "workspace_data": {
      "root": "<applet-sandbox>/workspace_data",
      "kind": "per_applet_root"
    }
  },
  "filesystem": {
    "files": [],
    "symlinks": []
  },
  "op": {
    "kind": "write",
    "handle": "workspace_data",
    "path": "drafts/note.txt",
    "bytes_base64": "aGVsbG8=",
    "content_type": "text/plain",
    "mode": "append"
  },
  "expect": "rejected",
  "error": {
    "kind": "ValidationError",
    "detail_contains": "only \"create_or_truncate\" is supported"
  },
  "trace_expectation": {
    "method": "files.write",
    "denial_recorded": true,
    "filesystem_touched": false
  },
  "reason": "create_or_truncate is the only write mode in M0a (spec/files.md); an append write is rejected as a recorded ValidationError before the payload decode, grant/confinement gate, or any filesystem touch, so an append request can never silently truncate the file while the trace claims append"
}
