    "symlinks": []
  },
  "ops": [
    {
      "kind": "write",
      "handle": "workspace_data",
      "path": "drafts/note.txt",
      "bytes_base64": "ZHJhZnQgdjE=",
      "content_type": "text/plain",
      "mode": "create_or_truncate"
