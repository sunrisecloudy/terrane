{
  "case": "absolute_path_rejected",
  "grant": {
    "files": {
      "read": [
        {
          "handle": "workspace_data",
          "path_glob": "**/*",
          "max_bytes": 65536,
          "content_types": [
            "text/plain"
          ]
        }
      ],
      "write": []
    }
  },
  "resolved_handles": {
    "workspace_data": {
      "root": "<applet-sandbox>/workspace_data",
      "kind": "per_applet_root"
    }
  },
  "filesystem": {
    "files": [],
    "symlinks": []
  },
  "op": {
    "kind": "read",
    "handle": "workspace_data",
    "path": "/etc/passwd",
    "encoding": "base64"
  },
  "expect": "rejected",
  "error": {
    "kind": "PermissionDenied",
    "detail_contains": "absolute paths are not allowed"
  },
  "trace_expectation": {
    "method": "files.read",
    "denial_recorded": true,
    "filesystem_touched": false
  },
  "reason": "native absolute paths cannot be smuggled through a user-granted handle"
}
