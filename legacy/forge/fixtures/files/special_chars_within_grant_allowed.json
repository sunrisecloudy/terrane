{
  "case": "special_chars_within_grant_allowed",
  "grant": {
    "files": {
      "read": [
        {
          "handle": "workspace_data",
          "path_glob": "data/*.json",
          "max_bytes": 65536,
          "content_types": [
            "application/json"
          ]
        }
      ],
      "write": []
    }
  },
  "resolved_handles": {
    "workspace_data": {
      "root": "<applet-sandbox>/workspace_data",
      "kind": "per_applet_root"
    }
  },
  "filesystem": {
    "files": [
      {
        "path": "data/report (final)+v1.json",
        "bytes_base64": "cmVwb3J0IChmaW5hbCkrdjE=",
        "content_type": "application/json"
      }
    ],
    "symlinks": []
  },
  "op": {
    "kind": "read",
    "handle": "workspace_data",
    "path": "data/report (final)+v1.json",
    "encoding": "base64"
  },
  "expect": "allowed",
  "response": {
    "path": "data/report (final)+v1.json",
    "bytes_base64": "cmVwb3J0IChmaW5hbCkrdjE=",
    "size": 17,
    "content_type": "application/json"
  },
  "trace_expectation": {
    "method": "files.read",
    "replay_touches_filesystem": false
  },
  "reason": "spaces, parentheses, plus signs, and digits are valid path characters when the path is relative and inside the grant"
}
