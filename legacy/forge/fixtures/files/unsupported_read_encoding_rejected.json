{
  "case": "unsupported_read_encoding_rejected",
  "grant": {
    "files": {
      "read": [
        {
          "handle": "workspace_data",
          "path_glob": "**/*",
          "max_bytes": 65536,
          "content_types": [
            "text/plain"
          ]
        }
      ],
      "write": []
    }
  },
  "resolved_handles": {
    "workspace_data": {
      "root": "<applet-sandbox>/workspace_data",
      "kind": "per_applet_root"
    }
  },
  "filesystem": {
    "files": [
      {
        "path": "data/note.txt",
        "bytes_base64": "aGVsbG8=",
        "content_type": "text/plain"
      }
    ],
    "symlinks": []
  },
  "op": {
    "kind": "read",
    "handle": "workspace_data",
    "path": "data/note.txt",
    "encoding": "utf8"
  },
  "expect": "rejected",
  "error": {
    "kind": "ValidationError",
    "detail_contains": "only \"base64\" is supported"
  },
  "trace_expectation": {
    "method": "files.read",
    "denial_recorded": true,
    "filesystem_touched": false
  },
  "reason": "base64 is the only read encoding in M0a (spec/files.md); a utf8 read is rejected as a recorded ValidationError before any grant/confinement gate or filesystem touch, so the trace never claims a non-base64 encoding while returning bytes_base64"
}
