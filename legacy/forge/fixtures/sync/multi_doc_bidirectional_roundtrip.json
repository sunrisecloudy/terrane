{
  "version": 1,
  "case": "multi_doc_bidirectional_roundtrip",
  "coverage": ["SS-1", "SS-2", "multi_doc_bidirectional_sync"],
  "peer_a_id": 101,
  "peer_b_id": 202,
  "seed": [
    {
      "op": "insert",
      "collection": "tasks",
      "id": "shared-task",
      "fields": {
        "status": "open",
        "title": "shared task"
      }
    },
    {
      "op": "insert",
      "collection": "notes",
      "id": "shared-note",
      "fields": {
        "body": "shared note"
      }
    }
  ],
  "seed_mode": "shared_history",
  "peer_a": [
    {
      "op": "patch",
      "collection": "tasks",
      "id": "shared-task",
      "fields": {
        "owner": "a"
      }
    },
    {
      "op": "insert",
      "collection": "notes",
      "id": "n-a",
      "fields": {
        "body": "a note"
      }
    }
  ],
  "peer_b": [
    {
      "op": "patch",
      "collection": "notes",
      "id": "shared-note",
      "fields": {
        "pinned": true
      }
    },
    {
      "op": "insert",
      "collection": "tasks",
      "id": "t-b",
      "fields": {
        "title": "b task"
      }
    }
  ],
  "sync": {
    "directions": ["a_to_b", "b_to_a"],
    "frontier": "exchanged_chunk_id_set_per_doc",
    "duplicate_chunks": false,
    "reorder_chunks": false
  },
  "expect_converged": {
    "notes": [
      {
        "id": "n-a",
        "fields": {
          "body": "a note"
        }
      },
      {
        "id": "shared-note",
        "fields": {
          "body": "shared note",
          "pinned": true
        }
      }
    ],
    "tasks": [
      {
        "id": "shared-task",
        "fields": {
          "owner": "a",
          "status": "open",
          "title": "shared task"
        }
      },
      {
        "id": "t-b",
        "fields": {
          "title": "b task"
        }
      }
    ]
  },
  "assertions": [
    "peer_a_projection_equals_peer_b_projection",
    "projection_equals_expect_converged"
  ]
}
