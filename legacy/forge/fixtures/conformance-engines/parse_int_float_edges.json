    "body": "export async function main(_ctx, _input) {\n  const j = (n) => (Number.isNaN(n) ? null : (n === Infinity ? 'Infinity' : (n === -Infinity ? '-Infinity' : n)));\n  return { ok: true, value: {\n    hex: parseInt('0xFF'), pad: parseInt('  42px'), radix2: parseInt('101', 2),\n    empty: j(parseInt('')), floatJunk: parseFloat('3.14abc'), expo: parseFloat('1e3'),\n    inf: j(parseFloat('Infinity')), bad: j(parseFloat('abc')), num: Number('  0x10  ')\n  } };\n}\n",
