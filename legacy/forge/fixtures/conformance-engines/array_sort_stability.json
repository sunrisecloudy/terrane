    "body": "export async function main(_ctx, _input) {\n  const items = [\n    { k: 1, id: 'a' }, { k: 2, id: 'b' }, { k: 1, id: 'c' },\n    { k: 2, id: 'd' }, { k: 1, id: 'e' }, { k: 0, id: 'f' }\n  ];\n  const sorted = items.slice().sort((x, y) => x.k - y.k).map(x => x.id);\n  const strs = ['banana', 'apple', 'cherry', 'apple'].slice().sort();\n  return { ok: true, value: { sorted, strs } };\n}\n",
