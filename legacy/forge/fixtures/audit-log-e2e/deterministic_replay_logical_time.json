{
  "case": "deterministic_replay_logical_time",
  "description": "Audit sequence and logical timestamps replay identically when the replay clock is externally supplied.",
  "given": {
    "recorded_audit_rows": [
      {
        "audit_id": "audit-000090",
        "seq": 90,
        "logical_time": 10001,
        "producer": "secrets",
        "action": "secret.use",
        "decision": "allow",
        "actor_id": "actor-runner-1",
        "resource_type": "secret",
        "resource_id": "secret_weather",
        "reason": "secret_ref injected into allowlisted header",
        "metadata": {"secret_ref": "secret_weather", "value_redacted": true}
      },
      {
        "audit_id": "audit-000091",
        "seq": 91,
        "logical_time": 10002,
        "producer": "net",
        "action": "network.egress",
        "decision": "allow",
        "actor_id": "actor-runner-1",
        "resource_type": "network",
        "resource_id": "https://api.weather.example",
        "reason": "network policy allowed request",
        "metadata": {"method": "GET", "host": "api.weather.example", "request_body_redacted": true, "response_body_redacted": true}
      }
    ],
    "replay_clock": {"next_seq": 90, "logical_time_start": 10000}
  },
  "when": {
    "replay": {
      "mode": "recorded-audit",
      "wall_clock": "ignored",
      "serve_rows_from_record": true
    }
  },
  "expect": {
    "replayed_audit_rows": [
      {
        "audit_id": "audit-000090",
        "seq": 90,
        "logical_time": 10001,
        "producer": "secrets",
        "action": "secret.use",
        "decision": "allow",
        "actor_id": "actor-runner-1",
        "resource_type": "secret",
        "resource_id": "secret_weather",
        "reason": "secret_ref injected into allowlisted header",
        "metadata": {"secret_ref": "secret_weather", "value_redacted": true}
      },
      {
        "audit_id": "audit-000091",
        "seq": 91,
        "logical_time": 10002,
        "producer": "net",
        "action": "network.egress",
        "decision": "allow",
        "actor_id": "actor-runner-1",
        "resource_type": "network",
        "resource_id": "https://api.weather.example",
        "reason": "network policy allowed request",
        "metadata": {"method": "GET", "host": "api.weather.example", "request_body_redacted": true, "response_body_redacted": true}
      }
    ],
    "byte_identical_audit_rows": true,
    "deterministic_time": "seq and logical_time are replayed from the record; wall clock is not consulted"
  }
}
