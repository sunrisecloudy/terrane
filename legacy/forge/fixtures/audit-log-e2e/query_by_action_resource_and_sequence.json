{
  "case": "query_by_action_resource_and_sequence",
  "description": "Audit-log queries by action, by resource, and by sequence range return the correct subset in sequence order.",
  "given": {
    "audit_rows": [
      {"audit_id": "audit-000070", "seq": 70, "logical_time": 8001, "producer": "permission-manager", "action": "permission.grant", "decision": "allow", "actor_id": "actor-owner-1", "resource_type": "capability", "resource_id": "db.write:collection:tasks", "collection": "tasks", "reason": "owner approved capability grant", "metadata": {}},
      {"audit_id": "audit-000071", "seq": 71, "logical_time": 8002, "producer": "net", "action": "network.egress", "decision": "allow", "actor_id": "actor-runner-1", "resource_type": "network", "resource_id": "https://api.example.com", "reason": "network policy allowed request", "metadata": {"host": "api.example.com", "method": "GET"}},
      {"audit_id": "audit-000072", "seq": 72, "logical_time": 8003, "producer": "permission-manager", "action": "permission.revoke", "decision": "allow", "actor_id": "actor-owner-1", "resource_type": "capability", "resource_id": "db.write:collection:tasks", "collection": "tasks", "reason": "owner revoked capability grant", "metadata": {}},
      {"audit_id": "audit-000073", "seq": 73, "logical_time": 8004, "producer": "sync-rbac", "action": "sync.record.insert", "decision": "deny", "actor_id": "actor-viewer-1", "resource_type": "record", "resource_id": "tasks", "collection": "tasks", "reason": "viewer cannot author remote record writes", "metadata": {}}
    ]
  },
  "when": {
    "queries": [
      {"name": "by_action", "where": {"action": "permission.revoke"}, "order_by": ["seq", "asc"]},
      {"name": "by_resource", "where": {"resource_id": "db.write:collection:tasks"}, "order_by": ["seq", "asc"]},
      {"name": "by_sequence_range", "where": {"seq_gte": 71, "seq_lte": 72}, "order_by": ["seq", "asc"]}
    ]
  },
  "expect": {
    "query_results": {
      "by_action": ["audit-000072"],
      "by_resource": ["audit-000070", "audit-000072"],
      "by_sequence_range": ["audit-000071", "audit-000072"]
    }
  }
}
