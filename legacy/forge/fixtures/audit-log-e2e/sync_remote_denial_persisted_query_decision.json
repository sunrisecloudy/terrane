        "seq": 1,
        "logical_time": 1001,
        "producer": "sync-rbac",
        "action": "sync.record.insert",
        "decision": "deny",
        "actor_id": "actor-viewer-1",
        "resource_type": "record",
        "resource_id": "tasks",
        "collection": "tasks",
        "reason": "viewer cannot author remote record writes",
        "metadata": {
          "source": "peer-viewer-1",
          "trusted_role": "Viewer",
          "trusted_db_read": ["tasks"],
          "trusted_db_write": [],
          "trusted_schema_write": false,
          "record_ids": ["tasks/task-101"]
        }
      }
    ],
    "query": {
      "where": {"decision": "deny"},
      "order_by": ["seq", "asc"],
      "result_audit_ids": ["audit-000001"]
    }
  }
}
