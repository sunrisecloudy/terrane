      "actor_id",
      "kind",
      "created_day"
    ]
  },
  "target_queries": [
    {
      "name": "by_actor",
      "filter": {
        "actor_id": "actor_42"
      },
      "expect_rows": 1000
    },
    {
      "name": "by_kind_day",
      "filter": {
        "kind": "kind_3",
        "created_day": "2026-01-04"
      },
      "expect_rows": "deterministic subset"
    }
  ]
}
