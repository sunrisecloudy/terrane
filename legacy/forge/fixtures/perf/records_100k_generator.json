{
  "case": "records_100k_generator",
  "collection": "events",
  "count": 100000,
  "deterministic_seed": "forge-perf-100k-v1",
  "fields": {
    "id": "evt_${i}",
    "actor_id": "actor_${i % 100}",
    "kind": "kind_${i % 12}",
    "created_day": "2026-01-${(i % 28)+1}",
