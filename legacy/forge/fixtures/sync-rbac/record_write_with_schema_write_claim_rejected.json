{
  "version": 1,
  "case": "record_write_with_schema_write_claim_rejected",
  "coverage": ["SS-7", "SC-9", "SC-10", "SC-11", "SC-12"],
  "trusted_peer": {
    "actor_id": "actor-editor-4",
    "role": "editor",
    "db_read": ["tasks"],
    "db_write": ["tasks"],
    "schema_write": false
  },
  "incoming_claim": {
    "actor_id": "actor-editor-4",
    "role": "editor",
    "db_read": ["tasks"],
    "db_write": ["tasks"],
    "schema_write": true
  },
  "incoming": {
    "frame": "live_update",
    "doc_id": "collection/tasks",
    "metadata": {
      "resource_type": "record",
      "op": "insert",
      "collection": "tasks",
      "record_id": "task-200",
      "schema_version": 1,
      "touched_records": ["tasks/task-200"]
    },
    "record_op": {
      "op": "insert",
      "collection": "tasks",
      "id": "task-200",
      "fields": {
        "title": "smuggle schema_write into a record write"
      }
    }
  },
  "expect": {
    "decision": "permission_denied",
    "error_frame": "permission_denied",
    "audit": {
      "action": "sync.record.insert",
      "decision": "deny",
      "reason_contains": "schema_write claim exceeds trusted membership"
    },
    "apply": {
      "import_chunk": false,
      "rebuild_projection": false
    }
  },
  "assertions": [
    "a schema_write claim that exceeds the trusted row is a self-escalation",
    "the widening is rejected before the op-specific record-write allow, so the editor cannot smuggle schema_write through a record op"
  ]
}
