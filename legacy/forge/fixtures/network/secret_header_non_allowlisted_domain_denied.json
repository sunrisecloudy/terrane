{
  "case": "secret_header_non_allowlisted_domain_denied",
  "allowlist": [
    {
      "method": "GET",
      "url": "https://api.example.com/private/*",
      "allow_secret_headers": [
        "Authorization"
      ]
    }
  ],
  "request": {
    "method": "GET",
    "url": "https://evil.example/private/me",
    "headers": {
      "Authorization": {
        "secret_ref": "secret_weather"
      }
    }
  },
  "expect": "deny",
  "reason": "secret ref cannot be injected into a non-allowlisted domain",
  "requires_runtime_dns": false
}
