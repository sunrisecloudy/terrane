{
  "case": "response_too_large_denied",
  "allowlist": [
    {
      "method": "GET",
      "url": "https://api.example.com/public/*",
      "max_response_bytes": 1024
    }
  ],
  "request": {
    "method": "GET",
    "url": "https://api.example.com/public/big",
    "response_bytes": 4096
  },
  "expect": "deny",
  "reason": "response exceeds max_response_bytes",
  "requires_runtime_dns": false
}
