{
  "case": "secret_header_allowed_to_bound_host",
  "allowlist": [
    {
      "method": "GET",
      "url": "https://api.example.com/private/*",
      "allow_secret_headers": [
        "Authorization"
      ]
    }
  ],
  "request": {
    "method": "GET",
    "url": "https://api.example.com/private/me",
    "headers": {
      "Authorization": {
        "secret_ref": "secret_weather"
      }
    }
  },
  "expect": "allow",
  "reason": "secret ref injected only into allowlisted host/header",
  "requires_runtime_dns": false
}
