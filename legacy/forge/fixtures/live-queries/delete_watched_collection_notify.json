{
  "case": "delete_watched_collection_notify",
  "description": "Deleting a watched record notifies with the deleted id and the post-delete result set.",
  "given": {
    "records": [
      {"collection": "tasks", "id": "tasks/1", "fields": {"title": "Ship", "done": false}, "deleted": false},
      {"collection": "tasks", "id": "tasks/2", "fields": {"title": "Keep", "done": false}, "deleted": false}
    ],
    "watches": [
      {"watch_id": "watch:tasks-open", "query": {"from": "tasks", "where": ["done", "=", false], "orderBy": ["id", "asc"]}}
    ],
    "next_version": 2
  },
  "when": {
    "mutation": {"op": "delete", "collection": "tasks", "id": "tasks/1"}
  },
  "expect": {
    "dirty_set": {"version": 2, "collections": {"tasks": ["tasks/1"]}},
    "notifications": [
      {
        "type": "db.watch.notification",
        "watch_id": "watch:tasks-open",
        "version": 2,
        "collection": "tasks",
        "record_ids": ["tasks/1"],
        "reason": "delete",
        "result_ids": ["tasks/2"],
        "coalesced": false
      }
    ]
  }
}

