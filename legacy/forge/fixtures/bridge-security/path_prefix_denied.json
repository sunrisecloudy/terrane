{
  "kind": "network",
  "network_policy": {
    "allow": [
      {
        "origin": "https://api.example.com",
        "methods": ["GET"],
        "pathPrefix": "/public"
      }
    ]
  },
  "request": {
    "url": "https://api.example.com/private/secret",
    "method": "GET"
  },
  "expect": "deny"
}