{
  "kind": "network",
  "network_policy": {
    "allow": [
      {
        "origin": "https://api.example.com",
        "methods": ["GET"],
        "allowedHeaders": ["content-type"]
      }
    ],
    "denyPrivateNetwork": true
  },
  "request": {
    "url": "http://127.0.0.1/status",
    "method": "GET"
  },
  "expect": "deny"
}