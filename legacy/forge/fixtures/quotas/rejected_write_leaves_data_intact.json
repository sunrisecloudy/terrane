{
  "case": "rejected_write_leaves_data_intact",
  "prd": "DL-22",
  "describe": "NEVER SILENT DELETION: on the real DL-4 records path, an over-quota write is rejected and the whole transaction rolls back — the prior record, the chunk substrate, and the accounted usage are all byte-for-byte intact, and the rejected record never lands",
  "collection": "tasks",
  "seed": [
    { "op": "insert", "id": "t1", "fields": { "title": "keep me intact" }, "logical_at": 1 }
  ],
  "assert": {
    "kind": "enforce",
    "set_policy": { "workspace_limit_eq_current_total": true },
    "write": { "op": "insert", "id": "t2", "fields": { "title": "does not fit" }, "logical_at": 2 },
    "expect": {
      "accepted": false,
      "error_code": "ResourceLimitExceeded",
      "error_contains": "no data was deleted",
      "record_intact": { "id": "t1", "fields": { "title": "keep me intact" } },
      "rejected_record_absent": "t2",
      "usage_unchanged": true,
      "no_new_chunk": true
    }
  }
}
