{
  "case": "over_category_cap_rejects",
  "prd": "DL-22",
  "describe": "a write that fits the workspace + per-applet budgets but exceeds a category cap (here: attachments) is REJECTED on the category scope — no single category may consume the whole workspace budget",
  "assert": {
    "kind": "decision",
    "usage": {
      "workspace_total_bytes": 500,
      "per_applet": [],
      "per_category": { "attachments": 500, "run_logs": 0, "retained_chunks": 0, "snapshots": 0, "cache": 0 }
    },
    "policy": { "workspace_limit": 100000, "per_applet_limit": 100000, "attachments_cap": 600, "approaching_threshold": 0.8 },
    "category": "attachments",
    "applet": null,
    "write_bytes": 200,
    "expect": {
      "decision": "over_quota",
      "scope": "category",
      "category": "attachments",
      "projected": 700,
      "limit": 600,
      "error_code": "ResourceLimitExceeded"
    }
  }
}
