{
  "case": "under_limit_is_ok",
  "prd": "DL-22",
  "describe": "a write well below the approaching threshold of every limit is allowed (Ok)",
  "assert": {
    "kind": "decision",
    "usage": {
      "workspace_total_bytes": 100,
      "per_applet": [{ "applet": "tasks", "collections_bytes": 100 }],
      "per_category": { "attachments": 0, "run_logs": 0, "retained_chunks": 100, "snapshots": 0, "cache": 0 }
    },
    "policy": { "workspace_limit": 10000, "per_applet_limit": 10000, "retained_chunks_cap": 10000, "approaching_threshold": 0.8 },
    "category": "retained_chunks",
    "applet": "tasks",
    "write_bytes": 50,
    "expect": { "decision": "ok" }
  }
}
