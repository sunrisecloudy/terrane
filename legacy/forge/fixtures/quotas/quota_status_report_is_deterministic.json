{
  "case": "quota_status_report_is_deterministic",
  "prd": "DL-22",
  "describe": "DETERMINISM: quota_usage reports per-applet collection storage + the per-category breakdown summed purely from persisted state; two reads are byte-equal and the report has the expected shape",
  "seed": {
    "records": [
      { "collection": "tasks", "id": "t1", "fields": { "title": "A" }, "logical_at": 1 },
      { "collection": "notes/inbox", "id": "n1", "fields": { "body": "hello" }, "logical_at": 2 }
    ],
    "attachments": ["attachment-one", "attachment-two"]
  },
  "assert": {
    "kind": "report",
    "expect": {
      "applets_present": ["notes", "tasks"],
      "categories_present": ["attachments", "run_logs", "retained_chunks", "snapshots", "cache"],
      "attachments_bytes_positive": true,
      "retained_chunks_bytes_positive": true,
      "workspace_total_is_sum_of_applets_plus_categories": true,
      "two_reads_byte_equal": true
    }
  }
}
