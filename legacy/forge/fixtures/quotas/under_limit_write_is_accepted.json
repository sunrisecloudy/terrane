{
  "case": "under_limit_write_is_accepted",
  "prd": "DL-22",
  "describe": "the enforcement is not over-eager: with a roomy workspace limit, a normal records write on the real path is ACCEPTED and the record lands",
  "collection": "tasks",
  "seed": [
    { "op": "insert", "id": "t1", "fields": { "title": "first" }, "logical_at": 1 }
  ],
  "assert": {
    "kind": "enforce",
    "set_policy": { "workspace_limit": 1073741824 },
    "write": { "op": "insert", "id": "t2", "fields": { "title": "second" }, "logical_at": 2 },
    "expect": {
      "accepted": true,
      "record_present": { "id": "t2", "fields": { "title": "second" } },
      "usage_within_workspace_limit_after_accept": true
    }
  }
}
