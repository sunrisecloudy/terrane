{
  "case": "attachment_dedup_same_bytes_once",
  "prd": "DL-22",
  "describe": "DEDUP: putting identical attachment bytes twice stores ONE blob (refcounted), accounts the attachments category ONCE, and returns the same content hash; distinct bytes add a second blob",
  "assert": {
    "kind": "dedup",
    "puts": [
      { "bytes": "the same attachment payload", "expect_stored_new": true,  "expect_refcount": 1 },
      { "bytes": "the same attachment payload", "expect_stored_new": false, "expect_refcount": 2 },
      { "bytes": "a different payload",          "expect_stored_new": true,  "expect_refcount": 1 }
    ],
    "expect": {
      "first_and_second_same_hash": true,
      "third_distinct_hash": true,
      "attachments_bytes_after_dedup_unchanged_between_puts_1_and_2": true,
      "attachments_bytes_increases_on_third": true
    }
  }
}
