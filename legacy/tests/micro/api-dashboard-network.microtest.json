{
  "id": "api-dashboard-network",
  "description": "Mock network status endpoint and verify dashboard renders API status.",
  "targetApps": [
    "api-dashboard"
  ],
  "platforms": [
    "reference-host",
    "macos",
    "linux",
    "windows",
    "android-emulator",
    "ios-simulator"
  ],
  "setup": [
    {
      "tool": "platform.validate_package",
      "args": {
        "path": "webapps/examples/api-dashboard"
      }
    },
    {
      "tool": "platform.sign_webapp_package",
      "args": {
        "path": "webapps/examples/api-dashboard"
      }
    },
    {
      "tool": "platform.install_webapp_package",
      "args": {
        "path": "webapps/examples/api-dashboard"
      }
    },
    {
      "tool": "platform.open_webapp",
      "args": {
        "appId": "api-dashboard"
      }
    },
    {
      "tool": "runtime.network_mock_set",
      "args": {
        "match": {
          "url": "https://api.example.test/status",
          "method": "GET"
        },
        "response": {
          "status": 200,
          "bodyText": "{\"service\":\"example\",\"ok\":true,\"latencyMs\":42}"
        }
      }
    },
    {
      "tool": "runtime.capabilities",
      "args": {}
    }
  ],
  "steps": [
    {
      "tool": "runtime.set_value",
      "args": {
        "testId": "api-url-input",
        "value": "https://api.example.test/status"
      }
    },
    {
      "tool": "runtime.click",
      "args": {
        "testId": "refresh-status-button"
      }
    },
    {
      "tool": "runtime.assert_bridge_call",
      "args": {
        "method": "network.request"
      }
    },
    {
      "tool": "runtime.assert_text",
      "args": {
        "text": "200"
      }
    },
    {
      "tool": "runtime.assert_no_console_errors",
      "args": {}
    }
  ],
  "teardown": [
    {
      "tool": "runtime.resource_usage",
      "args": {}
    },
    {
      "tool": "runtime.run_accessibility_audit",
      "args": {}
    },
    {
      "tool": "platform.create_snapshot",
      "args": {
        "type": "post-test"
      }
    }
  ]
}
