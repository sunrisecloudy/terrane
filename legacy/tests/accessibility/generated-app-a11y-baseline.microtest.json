{
  "id": "generated-app-a11y-baseline",
  "description": "Baseline accessibility checks for generated apps.",
  "targetApps": [
    "notes-lite",
    "task-workbench",
    "file-transformer",
    "api-dashboard",
    "core-replay-lab"
  ],
  "platforms": [
    "reference-host"
  ],
  "steps": [
    {
      "tool": "runtime.assert_visible",
      "args": {
        "selector": "main"
      }
    },
    {
      "tool": "runtime.press_key",
      "args": {
        "key": "Tab"
      }
    },
    {
      "tool": "runtime.assert_no_console_errors",
      "args": {}
    },
    {
      "tool": "runtime.assert_accessibility",
      "args": {
        "rule": "no_unlabeled_controls"
      }
    }
  ]
}
