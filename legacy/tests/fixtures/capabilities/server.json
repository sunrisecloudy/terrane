{
  "runtimeVersion": "0.1.0",
  "platform": "server",
  "target": "forge-server",
  "appId": "notes-lite",
  "devMode": false,
  "features": {
    "core.step": true,
    "runtime.capabilities": false,
    "runtime.snapshot": true,
    "runtime.replay": true,
    "storage.read": true,
    "storage.write": true,
    "storage.get": false,
    "storage.set": false,
    "storage.remove": false,
    "storage.list": false,
    "dialog.openFile": false,
    "dialog.saveFile": false,
    "notification.toast": false,
    "network.request": false,
    "app.log": false,
    "notebook.read": false,
    "notebook.write": false,
    "notebook.propose": false,
    "notebook.approve": false,
    "notebook.sync": true
  },
  "limits": {
    "maxBodyBytes": 1048576,
    "maxStorageBytes": 5242880,
    "maxBridgeCallsPerMinute": 600,
    "maxPackageBytes": 1048576,
    "maxFileBytes": 524288
  }
}
