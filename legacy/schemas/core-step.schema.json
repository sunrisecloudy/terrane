{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/core-step.schema.json",
  "title": "Core Step Input",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "app",
    "event"
  ],
  "properties": {
    "app": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]{2,63}$"
    },
    "event": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "payload": {}
      }
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
