{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/commands/applet.install.request.schema.json",
  "title": "applet.install request",
  "description": "Compile each source, validate the manifest, optionally verify an Ed25519 signed package, and store the applet.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "applet_id",
    "manifest",
    "sources"
  ],
  "properties": {
    "applet_id": {
      "type": "string",
      "minLength": 1
    },
    "manifest": {
      "$ref": "../applet-manifest.schema.json"
    },
    "sources": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "description": "Map of source path to TypeScript source text."
    },
    "signature": {
      "type": "object",
      "description": "Optional MP-4 signed package (T012 shape). When present, verified before install.",
      "additionalProperties": true,
      "properties": {
        "package": {
          "$ref": "../app-package.schema.json"
        },
        "signature": {
          "type": "string"
        },
        "public_key": {
          "type": "string"
        },
        "publisher_trust": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
