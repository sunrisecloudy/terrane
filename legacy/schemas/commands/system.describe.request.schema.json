{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/commands/system.describe.request.schema.json",
  "title": "system.describe request",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "names": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Optional command-name filter."
    },
    "namespace": {
      "type": "string",
      "description": "Optional namespace prefix filter."
    },
    "tier": {
      "type": "string",
      "enum": ["public", "operator", "admin", "debug"],
      "default": "public",
      "description": "Maximum visibility tier to include."
    },
    "include_inner": {
      "type": "boolean",
      "default": false,
      "description": "Include inner ctx.* reference entries."
    },
    "for_role": {
      "type": "string",
      "enum": ["owner", "maintainer", "editor", "runner", "viewer", "auditor", "reviewer"],
      "description": "Preview the catalog as-if this role (default = caller)."
    }
  }
}