{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/dev-control-response.schema.json",
  "title": "DevControlResponse",
  "type": "object",
  "required": ["ok"],
  "properties": {
    "ok": { "type": "boolean" },
    "result": {},
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": {}
      },
      "additionalProperties": false
    },
    "diagnostics": {
      "type": "object",
      "properties": {
        "target": { "type": "string" },
        "sessionId": { "type": "string" },
        "appId": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
