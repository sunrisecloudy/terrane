{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/app-migration.schema.json",
  "title": "App Data Migration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "appId",
    "fromDataVersion",
    "toDataVersion",
    "steps"
  ],
  "properties": {
    "appId": {
      "type": "string"
    },
    "fromDataVersion": {
      "type": "integer",
      "minimum": 1
    },
    "toDataVersion": {
      "type": "integer",
      "minimum": 2
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "op"
        ],
        "properties": {
          "op": {
            "type": "string",
            "enum": [
              "renameKey",
              "setDefault",
              "deleteKey",
              "copyKey",
              "transformEnum",
              "moveStorageKey",
              "deleteStorageKey"
            ]
          },
          "key": {
            "type": "string"
          },
          "from": {
            "type": "string"
          },
          "to": {
            "type": "string"
          },
          "value": {},
          "map": {
            "type": "object"
          }
        }
      }
    }
  }
}