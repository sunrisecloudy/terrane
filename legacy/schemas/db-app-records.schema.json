{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/db-app-records.schema.json",
  "title": "Database App Records",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "apps": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/app"
      }
    },
    "appVersions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/appVersion"
      }
    },
    "appFiles": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/appFile"
      }
    },
    "appPermissions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/appPermission"
      }
    },
    "appInstallations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/appInstallation"
      }
    },
    "appStorage": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/appStorage"
      }
    },
    "appMigrations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/appMigrationRecord"
      }
    },
    "appInstallReports": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/appInstallReportRecord"
      }
    }
  },
  "required": [
    "apps",
    "appVersions",
    "appFiles",
    "appPermissions",
    "appStorage"
  ],
  "$defs": {
    "jsonValue": {},
    "app": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "name",
        "status",
        "dataVersion",
        "createdAt",
        "updatedAt"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "status": {
          "enum": [
            "enabled",
            "disabled",
            "quarantined",
            "uninstalled"
          ]
        },
        "activeInstallId": {
          "type": [
            "string",
            "null"
          ]
        },
        "activeVersion": {
          "type": [
            "string",
            "null"
          ]
        },
        "dataVersion": {
          "type": "integer",
          "minimum": 1
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "appVersion": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "installId",
        "appId",
        "version",
        "runtimeVersion",
        "dataVersion",
        "manifest",
        "manifestHash",
        "contentHash",
        "status",
        "createdAt"
      ],
      "properties": {
        "installId": {
          "type": "string"
        },
        "appId": {
          "type": "string"
        },
        "version": {
          "type": "string"
        },
        "runtimeVersion": {
          "type": "string"
        },
        "dataVersion": {
          "type": "integer",
          "minimum": 1
        },
        "manifest": {
          "type": "object",
          "additionalProperties": true
        },
        "manifestHash": {
          "type": "string"
        },
        "contentHash": {
          "type": "string"
        },
        "signature": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        },
        "trustLevel": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "activatedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        }
      }
    },
    "appFile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "installId",
        "path",
        "contentHash",
        "sizeBytes",
        "createdAt"
      ],
      "properties": {
        "installId": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "contentText": {
          "type": [
            "string",
            "null"
          ]
        },
        "contentHash": {
          "type": "string"
        },
        "sizeBytes": {
          "type": "integer",
          "minimum": 0
        },
        "mime": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "appPermission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "installId",
        "appId",
        "permission",
        "requested",
        "approved"
      ],
      "properties": {
        "installId": {
          "type": "string"
        },
        "appId": {
          "type": "string"
        },
        "permission": {
          "type": "string"
        },
        "requested": {
          "type": "boolean"
        },
        "approved": {
          "type": "boolean"
        },
        "approvedAt": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "appInstallation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "installationEventId",
        "appId",
        "installId",
        "action",
        "actor",
        "createdAt"
      ],
      "properties": {
        "installationEventId": {
          "type": "string"
        },
        "appId": {
          "type": "string"
        },
        "installId": {
          "type": "string"
        },
        "action": {
          "enum": [
            "install",
            "activate",
            "disable",
            "rollback",
            "quarantine",
            "uninstall",
            "import"
          ]
        },
        "previousInstallId": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor": {
          "type": "string"
        },
        "reportId": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        },
        "details": {
          "type": [
            "object",
            "null"
          ],
          "additionalProperties": true
        }
      }
    },
    "appStorage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "appId",
        "key",
        "value",
        "updatedAt"
      ],
      "properties": {
        "appId": {
          "type": "string"
        },
        "key": {
          "type": "string"
        },
        "value": {},
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "appMigrationRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "migrationId",
        "appId",
        "fromDataVersion",
        "toDataVersion",
        "migration",
        "contentHash",
        "createdAt"
      ],
      "properties": {
        "migrationId": {
          "type": "string"
        },
        "appId": {
          "type": "string"
        },
        "fromDataVersion": {
          "type": "integer"
        },
        "toDataVersion": {
          "type": "integer"
        },
        "migration": {
          "type": "object"
        },
        "contentHash": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "appInstallReportRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "reportId",
        "appId",
        "status",
        "createdAt"
      ],
      "properties": {
        "reportId": {
          "type": "string"
        },
        "appId": {
          "type": "string"
        },
        "installId": {
          "type": [
            "string",
            "null"
          ]
        },
        "status": {
          "type": "string"
        },
        "validation": {
          "type": [
            "object",
            "null"
          ]
        },
        "security": {
          "type": [
            "object",
            "null"
          ]
        },
        "permissions": {
          "type": [
            "object",
            "null"
          ]
        },
        "compatibility": {
          "type": [
            "object",
            "null"
          ]
        },
        "smokeTest": {
          "type": [
            "object",
            "null"
          ]
        },
        "contentHash": {
          "type": [
            "string",
            "null"
          ]
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    }
  }
}
