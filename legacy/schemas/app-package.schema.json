{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/app-package.schema.json",
  "title": "Generated Webapp Package",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest",
    "files"
  ],
  "properties": {
    "manifest": {
      "$ref": "manifest.schema.json"
    },
    "files": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "path",
          "content"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "content": {
            "type": "string"
          }
        }
      }
    },
    "migrations": {
      "type": "array",
      "items": {
        "$ref": "app-migration.schema.json"
      }
    },
    "signature": {
      "$ref": "app-signature.schema.json"
    },
    "installReport": {
      "$ref": "install-report.schema.json"
    },
    "smokeTests": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}
