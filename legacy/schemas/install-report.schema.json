{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/install-report.schema.json",
  "title": "App Install Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "appId",
    "installId",
    "status",
    "validatedAt",
    "requiresUserApproval",
    "checks"
  ],
  "properties": {
    "appId": {
      "type": "string"
    },
    "installId": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "accepted",
        "accepted-with-warnings",
        "rejected",
        "quarantined",
        "requires-approval"
      ]
    },
    "validatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "requiresUserApproval": {
      "type": "boolean"
    },
    "signature": {
      "$ref": "app-signature.schema.json"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}