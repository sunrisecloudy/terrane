{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/accessibility-report.schema.json",
  "title": "Generated App Accessibility Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "appId",
    "checkedAt",
    "status",
    "checks"
  ],
  "properties": {
    "appId": {
      "type": "string"
    },
    "checkedAt": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "pass",
        "warn",
        "fail"
      ]
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "status"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "warn",
              "fail"
            ]
          },
          "message": {
            "type": "string"
          },
          "selector": {
            "type": "string"
          }
        }
      }
    }
  }
}