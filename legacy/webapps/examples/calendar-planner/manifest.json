{
  "id": "calendar-planner",
  "name": "Calendar Planner",
  "version": "0.1.0",
  "runtimeVersion": "0.1.0",
  "entry": "index.html",
  "description": "Local-first calendar planning with month navigation, agenda storage, and core event logging.",
  "contentRating": {
    "scheme": "app-store",
    "label": "4+",
    "minimumAge": 4,
    "descriptors": []
  },
  "permissions": [
    "core.step",
    "storage.read",
    "storage.write",
    "notification.toast",
    "app.log"
  ],
  "storagePrefix": "calendar-planner:",
  "dataVersion": 1,
  "capabilities": {
    "required": [
      "core.step",
      "storage.read",
      "storage.write"
    ],
    "optional": [
      "notification.toast",
      "app.log"
    ]
  },
  "resourceBudget": {
    "maxDomNodes": 2000,
    "maxStorageBytes": 5242880,
    "maxBridgeCallsPerMinute": 600,
    "maxNetworkRequestsPerMinute": 60,
    "maxTimers": 64,
    "maxLogLinesPerMinute": 120,
    "maxPackageBytes": 1048576,
    "maxFileBytes": 524288
  },
  "networkPolicy": {
    "allow": []
  },
  "trust": {
    "level": "bundled",
    "requiresUserApproval": false
  },
  "compatibility": {
    "mode": "strict",
    "minimumRuntimeVersion": "0.1.0"
  },
  "authorId": "example-fixture"
}
