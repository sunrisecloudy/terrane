{
  "$id": "query.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "where": {
      "$ref": "#/$defs/filter"
    },
    "orderBy": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["field"],
        "additionalProperties": false,
        "properties": {
          "field": {
            "type": "string"
          },
          "direction": {
            "type": "string",
            "enum": ["asc", "desc"]
          }
        }
      }
    },
    "limit": {
      "type": "integer",
      "minimum": 0,
      "maximum": 1000
    },
    "offset": {
      "type": "integer",
      "minimum": 0
    }
  },
  "$defs": {
    "filter": {
      "oneOf": [
        {
          "type": "object",
          "required": ["field", "op", "value"],
          "additionalProperties": false,
          "properties": {
            "field": {
              "type": "string"
            },
            "op": {
              "type": "string",
              "enum": ["eq", "ne", "lt", "lte", "gt", "gte", "in", "contains"]
            },
            "value": {}
          }
        },
        {
          "type": "object",
          "required": ["and"],
          "additionalProperties": false,
          "properties": {
            "and": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/filter"
              },
              "minItems": 1
            }
          }
        },
        {
          "type": "object",
          "required": ["or"],
          "additionalProperties": false,
          "properties": {
            "or": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/filter"
              },
              "minItems": 1
            }
          }
        }
      ]
    }
  }
}
