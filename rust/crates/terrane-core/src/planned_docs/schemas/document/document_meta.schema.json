{
  "$id": "document_meta.schema.json",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "title": {
      "type": "string",
      "maxLength": 256
    },
    "contentType": {
      "type": "string",
      "enum": ["text/markdown", "text/plain", "application/json"]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "maxLength": 64
      },
      "maxItems": 32
    }
  }
}
